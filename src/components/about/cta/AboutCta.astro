---
import Button from '@/components/ui/Button.astro';
---
  <section
    id="about-cta"
    class="grid grid-cols-1 items-center gap-10 bg-dark-red px-5 py-20 md:gap-20 md:px-10 lg:grid-cols-[2fr_1fr] lg:gap-20 lg:px-20 lg:py-[110px]"
  >
    <div>
      <h2 class="font-serif text-[clamp(28px,3.5vw,48px)] font-light leading-tight text-cream">
        Ready to Create<br /><em class="italic">Your Unforgettable Feast?</em>
      </h2>
      <p class="mt-4 max-w-xl font-body text-lg leading-[1.8] text-cream/65">
        Speak to our event specialists. We'll listen to your vision, understand your occasion, and craft a bespoke
        culinary experience that exceeds every expectation.
      </p>
    </div>
    <div class="flex flex-col items-start gap-3.5">
      <Button href="#">Get a Quote</Button>
      <Button href="#" variant="outlineCream">View Menus</Button>
    </div>
  </section>
