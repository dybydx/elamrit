            href="#"
            title="LinkedIn">LI</a
          >
        </div>
      </div>
      <div class="footer-col">
        <h4 class="mb-5 font-body text-[12px] tracking-[0.26em] text-cream uppercase">Services</h4>
        <ul class="flex list-none flex-col gap-2.5">
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Wedding Catering</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Corporate Events</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Social Celebrations</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Private Dining</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Live Stations</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Pan India Catering</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="mb-5 font-body text-[12px] tracking-[0.26em] text-cream uppercase">Company</h4>
        <ul class="flex list-none flex-col gap-2.5">
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="/about">About Elamrit</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Our Story</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">Our Team</a></li>
          <li><a class="font-body text-[16px] text-[rgba(214,185,171,0.6)] transition-colors hover:text-cream" href="#">The Journal</a></li>
