  <footer class="border-t-[3px] border-green bg-dark-red px-5 py-12 pb-8 text-blush md:px-10 lg:px-20 lg:pt-[72px]">
    <div
      class="grid grid-cols-1 gap-10 border-b border-[rgba(189,148,118,0.12)] pb-14 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] lg:gap-[60px]"
    >
      <div class="footer-brand">
        <div class="logo-name mb-1 font-display text-[22px] tracking-[0.4em] text-cream">ELAMRIT</div>
        <div class="logo-tag mb-5 font-serif text-[11px] tracking-[0.26em] text-gray-orange uppercase">
          Luxe Feast
        </div>
        <p class="mb-7 max-w-[280px] font-body text-[16px] leading-[1.8] text-[rgba(214,185,171,0.6)]">
          Premium catering crafted for life's most significant moments. Pune-based. Pan India. Singapore — coming soon.
        </p>
        <div class="flex gap-3.5">
          <a
            class="flex h-[34px] w-[34px] items-center justify-center border border-[rgba(189,148,118,0.2)] text-[10px] text-gray-orange transition-all duration-200 hover:border-gray-orange hover:text-cream"
            href="#"
            title="Instagram">IG</a
          >
          <a
            class="flex h-[34px] w-[34px] items-center justify-center border border-[rgba(189,148,118,0.2)] text-[10px] text-gray-orange transition-all duration-200 hover:border-gray-orange hover:text-cream"
            href="#"
            title="Facebook">FB</a
