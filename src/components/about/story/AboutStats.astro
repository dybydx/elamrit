---
import Card from '@/components/ui/Card.astro';
---
  <section
    id="stats"
    class="grid grid-cols-1 gap-px bg-[rgba(81,3,12,0.06)] px-5 py-10 sm:grid-cols-2 lg:grid-cols-4 lg:px-20 lg:py-20"
  >
    <Card variant="statTile">
      <div class="font-display text-[52px] leading-none tracking-wide text-dark-red">500</div>
      <div class="font-serif text-lg italic text-gray-orange">+ Events</div>
      <div class="font-body text-[11px] tracking-[0.2em] text-dark-brown/60 uppercase">Crafted with care</div>
    </Card>
    <Card variant="statTile">
      <div class="font-display text-[52px] leading-none tracking-wide text-dark-red">12</div>
      <div class="font-serif text-lg italic text-gray-orange">+ Cities</div>
      <div class="font-body text-[11px] tracking-[0.2em] text-dark-brown/60 uppercase">Served across India</div>
    </Card>
    <Card variant="statTile">
      <div class="font-display text-[52px] leading-none tracking-wide text-dark-red">50</div>
      <div class="font-serif text-lg italic text-gray-orange">+ Artisans</div>
      <div class="font-body text-[11px] tracking-[0.2em] text-dark-brown/60 uppercase">Chefs & specialists</div>
    </Card>
    <Card variant="statTile">
      <div class="font-display text-[52px] leading-none tracking-wide text-dark-red">98%</div>
      <div class="font-serif text-lg italic text-gray-orange">Delight Score</div>
      <div class="font-body text-[11px] tracking-[0.2em] text-dark-brown/60 uppercase">Client satisfaction</div>
    </Card>
  </section>
