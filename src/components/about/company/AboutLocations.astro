---
import Card from '@/components/ui/Card.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
---
  <section
    id="locations"
    class="px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]"
    style="background: var(--bg-locations)"
  >
    <SectionHeader
      class="mb-0"
      label="Where We Serve"
      labelClass="mb-3.5"
      titleClass="text-[clamp(28px,3vw,42px)]"
    >
        From Pune to Pan India — <em class="italic text-dark-red">and Beyond</em>
    </SectionHeader>
    <div class="mt-14 grid grid-cols-1 gap-0.5 sm:grid-cols-2 lg:grid-cols-4">
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — West</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Pune</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Our home and headquarters. Where every idea is born and every standard is set.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Headquarters</span
        >
      </Card>
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — West</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Mumbai</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Corporate events, luxury weddings, and social celebrations across the city.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Active</span
        >
      </Card>
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — North</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Delhi NCR</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Grand weddings and corporate galas in the capital and surrounding region.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Active</span
        >
      </Card>
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — South</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Bangalore</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Tech-sector corporate catering and premium social events in the garden city.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Active</span
        >
      </Card>
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — Nationwide</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Pan India</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Destination weddings and special events anywhere across India — full logistics, full service.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Full Service</span
        >
      </Card>
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — South</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Hyderabad</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Biryani country — where our regional menus meet local culinary traditions.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Active</span
        >
      </Card>
      <Card variant="location">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >India — West</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Goa</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Beach weddings, resort events, and destination celebrations on the Konkan coast.
        </p>
        <span
          class="loc-status active mt-3.5 inline-flex items-center rounded-sm border border-dark-red/50 bg-cream px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-red uppercase"
          >Active</span
        >
      </Card>
      <Card variant="locationSg">
        <span class="loc-flag mb-3 block font-body text-xs tracking-[0.26em] text-dark-red uppercase"
          >Southeast Asia</span
        >
        <div class="loc-name mb-2 font-serif text-[22px] font-normal text-dark-brown">Singapore</div>
        <p class="loc-desc font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Our next frontier — bringing India's finest catering to Singapore's cosmopolitan dining scene.
        </p>
        <span
          class="loc-status coming mt-3.5 inline-flex items-center rounded-sm border border-dark-brown/25 bg-green px-3 py-1.5 font-body text-xs font-medium tracking-[0.14em] text-dark-brown uppercase"
          >Coming Soon</span
        >
      </Card>
    </div>
  </section>
