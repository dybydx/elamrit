---
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
---
  <section id="team" class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]">
    <div class="mb-16">
      <SectionEyebrow class="mb-4">The People Behind the Feast</SectionEyebrow>
      <h2 class="mt-3 font-serif text-[clamp(28px,3vw,44px)] font-light text-dark-brown">
        Masters of Their <em class="italic text-dark-red">Craft</em>
      </h2>
    </div>
    <div class="grid w-full grid-cols-1 gap-7 sm:grid-cols-2 lg:grid-cols-2 lg:gap-10">
      <Card variant="bare" class="team-card">
        <div
          class="team-photo relative mb-5 aspect-[3/4] overflow-hidden bg-[color-mix(in_srgb,var(--cream)_70%,var(--gray-orange)_30%)]"
        >
          <div
            class="photo-label absolute right-0 bottom-0 left-0 z-[1] p-4 font-body text-xs tracking-[0.18em] text-cream/45 uppercase"
          >
            Co-Founder
          </div>
        </div>
        <h3 class="team-name mb-1 font-serif text-xl font-normal text-dark-brown">Prajakta Dandawate</h3>
        <div class="team-role mb-2.5 font-body text-[13px] tracking-[0.18em] text-dark-red uppercase">
          Co-Founder
        </div>
        <p class="team-bio font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream-soft)]">
          Prajakta shapes Elamrit's partnerships, guest experience, and the narrative behind every celebration — from
          first conversation to the final toast.
        </p>
      </Card>
      <Card variant="bare" class="team-card">
        <div
          class="team-photo relative mb-5 aspect-[3/4] overflow-hidden bg-[color-mix(in_srgb,var(--cream)_70%,var(--gray-orange)_30%)]"
        >
          <div
            class="photo-label absolute right-0 bottom-0 left-0 z-[1] p-4 font-body text-xs tracking-[0.18em] text-cream/45 uppercase"
          >
            Co-Founder
          </div>
        </div>
        <h3 class="team-name mb-1 font-serif text-xl font-normal text-dark-brown">Kaustubh Jayade</h3>
        <div class="team-role mb-2.5 font-body text-[13px] tracking-[0.18em] text-dark-red uppercase">
          Co-Founder
        </div>
        <p class="team-bio font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream-soft)]">
          Kaustubh leads culinary vision and delivery — ensuring each menu, service rhythm, and production detail meets
          Elamrit's standard across Pune and Pan India.
        </p>
      </Card>
    </div>
  </section>
