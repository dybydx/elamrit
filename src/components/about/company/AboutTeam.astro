---
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
---
  <section id="team" class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]">
    <div class="mb-16">
      <SectionEyebrow class="mb-4">The People Behind the Feast</SectionEyebrow>
      <h2 class="mt-3 font-serif text-[clamp(28px,3vw,44px)] font-light text-dark-brown">
        Masters of Their <em class="italic text-dark-red">Craft</em>
      </h2>
    </div>
    <div class="grid grid-cols-1 gap-7 sm:grid-cols-2 lg:grid-cols-4 lg:gap-7">
      <Card variant="bare" class="team-card">
        <div
          class="team-photo relative mb-5 aspect-[3/4] overflow-hidden bg-[color-mix(in_srgb,var(--cream)_70%,var(--gray-orange)_30%)]"
        >
          <div
            class="photo-label absolute right-0 bottom-0 left-0 z-[1] p-4 font-body text-[9px] tracking-[0.2em] text-cream/40 uppercase"
          >
            Executive Chef
          </div>
        </div>
        <h3 class="team-name mb-1 font-serif text-xl font-normal text-dark-brown">Arjun Deshmukh</h3>
        <div class="team-role mb-2.5 font-body text-[11px] tracking-[0.2em] text-dark-red uppercase">
          Executive Chef & Co-Founder
        </div>
        <p class="team-bio font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream-soft)]">
          With 18 years across India's finest hotels and private kitchens, Arjun brings an unrivalled command of both
          classical Indian and contemporary global cuisine.
        </p>
      </Card>
      <Card variant="bare" class="team-card">
        <div
          class="team-photo relative mb-5 aspect-[3/4] overflow-hidden bg-[color-mix(in_srgb,var(--cream)_70%,var(--gray-orange)_30%)]"
        >
          <div
            class="photo-label absolute right-0 bottom-0 left-0 z-[1] p-4 font-body text-[9px] tracking-[0.2em] text-cream/40 uppercase"
          >
            Creative Director
          </div>
        </div>
        <h3 class="team-name mb-1 font-serif text-xl font-normal text-dark-brown">Priya Iyer</h3>
        <div class="team-role mb-2.5 font-body text-[11px] tracking-[0.2em] text-dark-red uppercase">
          Creative Director & Co-Founder
        </div>
        <p class="team-bio font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream-soft)]">
          Priya leads the visual and experiential design of every event — from tablescapes to live counter choreography.
          She trained in hospitality design in Milan and London.
        </p>
      </Card>
      <Card variant="bare" class="team-card">
        <div
          class="team-photo relative mb-5 aspect-[3/4] overflow-hidden bg-[color-mix(in_srgb,var(--cream)_70%,var(--gray-orange)_30%)]"
        >
          <div
            class="photo-label absolute right-0 bottom-0 left-0 z-[1] p-4 font-body text-[9px] tracking-[0.2em] text-cream/40 uppercase"
          >
            Head Pâtissier
          </div>
        </div>
        <h3 class="team-name mb-1 font-serif text-xl font-normal text-dark-brown">Kavita Rao</h3>
        <div class="team-role mb-2.5 font-body text-[11px] tracking-[0.2em] text-dark-red uppercase">
          Head Pâtissier
        </div>
        <p class="team-bio font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream-soft)]">
          Kavita's artisan desserts and confectionery have become an Elamrit signature — a marriage of French technique
          and Indian soul that leaves guests speechless.
        </p>
      </Card>
      <Card variant="bare" class="team-card">
        <div
          class="team-photo relative mb-5 aspect-[3/4] overflow-hidden bg-[color-mix(in_srgb,var(--cream)_70%,var(--gray-orange)_30%)]"
        >
          <div
            class="photo-label absolute right-0 bottom-0 left-0 z-[1] p-4 font-body text-[9px] tracking-[0.2em] text-cream/40 uppercase"
          >
            Events Director
          </div>
        </div>
        <h3 class="team-name mb-1 font-serif text-xl font-normal text-dark-brown">Siddharth Mehta</h3>
        <div class="team-role mb-2.5 font-body text-[11px] tracking-[0.2em] text-dark-red uppercase">
          Director, Event Experience
        </div>
        <p class="team-bio font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream-soft)]">
          Siddharth ensures every event unfolds with military precision and effortless grace — managing Pan India
          logistics, vendor relations, and service excellence.
        </p>
      </Card>
    </div>
  </section>
