---
import Button from '@/components/ui/Button.astro';
---
  <section id="gallery" class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]">
    <div class="gallery-intro mb-12 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <h2 class="max-w-[380px] font-serif text-[clamp(28px,3vw,42px)] font-light leading-snug text-dark-brown">
        A Taste of What <em class="italic text-dark-red">We Create</em>
      </h2>
      <Button href="#" variant="linkDarkRed">View Full Gallery</Button>
    </div>
    <div
      class="grid grid-cols-1 gap-1.5 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr] lg:grid-rows-[260px_260px]"
    >
      <div
        class="g-item relative min-h-[280px] overflow-hidden bg-[var(--bg-gallery-tile)] md:col-span-2 lg:col-span-1 lg:row-span-2 lg:min-h-0"
      >
        <div class="g-item-bg g-item-bg-1 h-full min-h-[inherit] w-full"></div>
        <div class="g-item-overlay"></div>
        <span
          class="absolute bottom-4 left-[18px] font-body text-[10px] tracking-[0.2em] text-cream/60 uppercase"
          >Wedding Feast</span
        >
      </div>
      <div class="g-item relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0">
        <div class="g-item-bg g-item-bg-2 h-full w-full"></div>
        <div class="g-item-overlay"></div>
        <span
          class="absolute bottom-4 left-[18px] font-body text-[10px] tracking-[0.2em] text-cream/60 uppercase"
          >Artisan Plating</span
        >
      </div>
      <div class="g-item relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0">
        <div class="g-item-bg g-item-bg-3 h-full w-full"></div>
        <div class="g-item-overlay"></div>
        <span
          class="absolute bottom-4 left-[18px] font-body text-[10px] tracking-[0.2em] text-cream/60 uppercase"
          >Live Station</span
        >
      </div>
      <div class="g-item relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0">
        <div class="g-item-bg g-item-bg-4 h-full w-full"></div>
        <div class="g-item-overlay"></div>
        <span
          class="absolute bottom-4 left-[18px] font-body text-[10px] tracking-[0.2em] text-cream/60 uppercase"
          >Corporate Event</span
        >
      </div>
      <div class="g-item relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0">
        <div class="g-item-bg g-item-bg-5 h-full w-full"></div>
        <div class="g-item-overlay"></div>
        <span
          class="absolute bottom-4 left-[18px] font-body text-[10px] tracking-[0.2em] text-cream/60 uppercase"
          >Private Dining</span
        >
      </div>
    </div>
  </section>
