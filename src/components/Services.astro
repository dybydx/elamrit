---
---
  <!-- ═══ SERVICES ══════════════════════════════════════════════ -->
  <section id="services">
    <div class="section-header">
      <span class="label">What We Do</span>
      <h2>Curated Services for <em>Every Occasion</em></h2>
      <div class="divider"></div>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <span class="service-num">01</span>
        <svg class="service-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M20 4C20 4 8 12 8 22C8 28.6 13.4 34 20 34C26.6 34 32 28.6 32 22C32 12 20 4 20 4Z" />
          <path d="M20 14V34M14 20L20 14L26 20" />
        </svg>
        <h3 class="service-title">Wedding Catering</h3>
        <p class="service-desc">From grand Hindu ceremonies to intimate destination weddings, we orchestrate culinary
          narratives that honour your most significant celebration.</p>
        <span class="service-link">Explore Weddings</span>
      </div>
      <div class="service-card">
        <span class="service-num">02</span>
        <svg class="service-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
          <rect x="6" y="10" width="28" height="22" rx="1" />
          <path d="M14 10V8M26 10V8" />
          <path d="M6 16h28" />
          <path d="M14 22h4M22 22h4M14 27h4" />
        </svg>
        <h3 class="service-title">Corporate Catering</h3>
        <p class="service-desc">Board meetings, product launches, annual galas — premium catering solutions that reflect
          your organisation's stature and ambition.</p>
        <span class="service-link">Corporate Services</span>
      </div>
      <div class="service-card">
        <span class="service-num">03</span>
        <svg class="service-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="20" cy="20" r="14" />
          <path d="M20 10v10l7 4" />
          <path d="M10 20h4M26 20h4M20 10v4M20 26v4" />
        </svg>
        <h3 class="service-title">Social Celebrations</h3>
        <p class="service-desc">Birthdays, anniversaries, cocktail evenings — turning everyday milestones into
          extraordinary memories through food and experience.</p>
        <span class="service-link">Social Events</span>
      </div>
      <div class="service-card">
        <span class="service-num">04</span>
        <svg class="service-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M8 32C8 32 10 16 20 10C30 16 32 32 32 32" />
          <path d="M14 26C14 26 16 20 20 18C24 20 26 26 26 26" />
          <line x1="8" y1="32" x2="32" y2="32" />
        </svg>
        <h3 class="service-title">Private Dining</h3>
        <p class="service-desc">Bespoke in-home dining experiences. A personal chef, curated menu, and impeccable
          service — all within the intimacy of your space.</p>
        <span class="service-link">Private Dining</span>
      </div>
    </div>
  </section>
