---
---
  <section
    id="food-junction"
    class="grid min-h-[460px] grid-cols-1 border-t-[3px] border-green lg:grid-cols-2"
  >
    <div
      class="flex flex-col justify-center px-8 py-16 lg:border-r lg:border-[color-mix(in_srgb,var(--dark-red)_18%,transparent)] lg:px-20 lg:py-20"
      style="background: var(--fj-panel-left)"
    >
      <div class="mb-5 flex items-center gap-3 font-body text-[10px] tracking-[0.35em] text-dark-red uppercase">
        <span class="block h-px w-7 bg-dark-red" aria-hidden="true"></span>
        Our Sister Brand
      </div>
      <h2 class="mb-1.5 font-display text-[28px] tracking-[0.3em] text-dark-brown uppercase">Food Junction</h2>
      <div
        class="mb-7 font-serif text-[15px] tracking-[0.25em] text-[color-mix(in_srgb,var(--dark-brown)_65%,var(--green)_35%)] uppercase"
      >
        Caterers
      </div>
      <p class="mb-10 max-w-[380px] font-body text-[17px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Quality catering that fits every budget. Food Junction brings the Elamrit commitment to flavour and service to
        corporate tiffins, office lunches, and smaller celebrations — without the luxe price tag.
      </p>
      <a href="#" class="btn-green">Explore Food Junction</a>
    </div>
    <div
      class="flex flex-col justify-center gap-1.5 px-8 py-12 md:px-12 lg:px-[72px] lg:py-16"
      style="background: var(--fj-panel-right)"
    >
      <div
        class="flex items-start gap-5 border border-[rgba(189,148,118,0.35)] border-l-[3px] border-l-green bg-[color-mix(in_srgb,var(--cream)_94%,var(--white)_6%)] px-6 py-5 shadow-[0_6px_28px_rgba(36,33,31,0.06)] transition-[border-color,background,box-shadow] duration-200 hover:border-dark-red/20 hover:border-l-dark-red hover:bg-cream hover:shadow-[0_10px_36px_rgba(81,3,12,0.08)]"
      >
        <div class="shrink-0 pt-0.5 font-display text-[26px] leading-none tracking-wide text-dark-red/90">01</div>
        <div>
          <h4 class="mb-1.5 font-serif text-[19px] font-normal text-dark-brown">Corporate Tiffin Service</h4>
          <p class="font-body text-[15px] leading-relaxed text-[var(--text-muted-on-cream)]">
            Daily office meals and corporate lunch packages crafted for teams of all sizes.
          </p>
        </div>
      </div>
      <div
        class="flex items-start gap-5 border border-[rgba(189,148,118,0.35)] border-l-[3px] border-l-green bg-[color-mix(in_srgb,var(--cream)_94%,var(--white)_6%)] px-6 py-5 shadow-[0_6px_28px_rgba(36,33,31,0.06)] transition-[border-color,background,box-shadow] duration-200 hover:border-dark-red/20 hover:border-l-dark-red hover:bg-cream hover:shadow-[0_10px_36px_rgba(81,3,12,0.08)]"
      >
        <div class="shrink-0 pt-0.5 font-display text-[26px] leading-none tracking-wide text-dark-red/90">02</div>
        <div>
          <h4 class="mb-1.5 font-serif text-[19px] font-normal text-dark-brown">Budget Event Catering</h4>
          <p class="font-body text-[15px] leading-relaxed text-[var(--text-muted-on-cream)]">
            Weddings, birthdays, and social events with full-service catering at accessible price points.
          </p>
        </div>
      </div>
      <div
        class="flex items-start gap-5 border border-[rgba(189,148,118,0.35)] border-l-[3px] border-l-green bg-[color-mix(in_srgb,var(--cream)_94%,var(--white)_6%)] px-6 py-5 shadow-[0_6px_28px_rgba(36,33,31,0.06)] transition-[border-color,background,box-shadow] duration-200 hover:border-dark-red/20 hover:border-l-dark-red hover:bg-cream hover:shadow-[0_10px_36px_rgba(81,3,12,0.08)]"
      >
        <div class="shrink-0 pt-0.5 font-display text-[26px] leading-none tracking-wide text-dark-red/90">03</div>
        <div>
          <h4 class="mb-1.5 font-serif text-[19px] font-normal text-dark-brown">Transparent Packages</h4>
          <p class="font-body text-[15px] leading-relaxed text-[var(--text-muted-on-cream)]">
            Clear pricing, no hidden costs. Get an instant quote for your event within 24 hours.
          </p>
        </div>
      </div>
    </div>
  </section>
