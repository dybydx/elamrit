---
import Button from '@/components/ui/Button.astro';

const heroContentClasses =
  'relative z-[2] mx-auto max-w-[880px] px-12 text-center max-[1024px]:max-w-[680px] max-[1024px]:px-8';
const heroEyebrowClasses =
  'mb-8 font-body text-xs tracking-[0.45em] text-cream/90 uppercase opacity-0 [animation:fade-up_1s_0.1s_ease_forwards] [text-shadow:0_1px_18px_rgba(0,0,0,0.7)]';
const heroBrandNameClasses =
  'mb-0 font-display leading-none text-cream opacity-0 text-[clamp(70px,12vw,168px)] tracking-[0.08em] [animation:fade-up_1s_0.35s_ease_forwards] [text-shadow:0_2px_40px_rgba(0,0,0,0.5)] max-[1024px]:text-[clamp(60px,14vw,120px)] max-[640px]:text-[clamp(52px,16vw,90px)]';
const heroOrnamentClasses =
  'mx-auto mb-5 mt-[18px] flex items-center justify-center gap-[18px] opacity-0 [animation:fade-up_1s_0.55s_ease_forwards]';
const heroOrnamentLineClasses =
  'h-px max-w-20 flex-1 opacity-75 max-[640px]:max-w-10';
const heroTaglineClasses =
  'font-display text-[clamp(12px,1.6vw,18px)] tracking-[0.6em] text-blush uppercase [text-shadow:0_1px_16px_rgba(0,0,0,0.65)]';
const heroDescriptionClasses =
  'mx-auto mb-11 mt-7 max-w-[620px] font-serif text-[clamp(19px,2.1vw,24px)] leading-[1.65] font-light italic text-cream/80 opacity-0 [animation:fade-up_1s_0.72s_ease_forwards] max-[640px]:text-lg';
const heroActionsClasses =
  'flex flex-wrap items-center justify-center gap-[22px] opacity-0 [animation:fade-up_1s_0.92s_ease_forwards] max-md:flex-col max-md:gap-3.5';
const heroScrollHintClasses =
  'absolute bottom-11 left-1/2 z-[3] flex -translate-x-1/2 flex-col items-center gap-2.5 font-body text-[9px] tracking-[0.3em] text-gray-orange/55 uppercase opacity-0 [animation:fade-in_1.5s_1.6s_ease_forwards]';
const scrollLineClasses =
  'block h-11 w-px [background:linear-gradient(to_bottom,var(--gray-orange),transparent)] [animation:scroll-pulse_2s_1.6s_ease-in-out_infinite]';
const muteButtonClasses =
  'video-mute-btn absolute right-5 bottom-10 z-[4] flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border border-gray-orange/30 bg-dark-brown/55 text-cream opacity-0 backdrop-blur-md transition-all duration-300 [animation:fade-in_1s_1.8s_ease_forwards] hover:border-gray-orange hover:bg-[rgba(81,3,12,0.8)] md:right-8 lg:right-[60px] max-[640px]:bottom-[100px] max-[640px]:right-5';
---
  <!-- ═══ HERO — FULL-SCREEN VIDEO ══════════════════════════════ -->
  <section
    id="hero"
    class="relative flex h-screen min-h-[620px] items-center justify-center overflow-hidden"
  >
    <div class="hero-video-bg absolute inset-0 z-0">
      <!--
        VIDEO PLACEHOLDER — replace `src` with /videos/hero-reel.mp4 or CDN URL.
        Recommended: 1920×1080 H.264, 15–30s loop, <15MB
      -->
      <video
        id="heroVideo"
        class="h-full w-full object-cover"
        autoplay
        loop
        muted
        playsinline
        poster="https://images.unsplash.com/photo-1555244162-803834f70033?auto=format&fit=crop&w=1920&q=85"
        src="/videos/hero-reel.mp4"
      >
      </video>
    </div>

    <div class="hero-overlay" aria-hidden="true"></div>

    <div class={heroContentClasses}>
      <div class={heroEyebrowClasses}>Pune &nbsp;&middot;&nbsp; Mumbai &nbsp;&middot;&nbsp; Pan India</div>

      <h1 class={heroBrandNameClasses}>ELAMRIT</h1>

      <div class={heroOrnamentClasses}>
        <span class={heroOrnamentLineClasses} style="background: linear-gradient(to right, transparent, var(--blush));"></span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 2C12 2 7.5 7.5 7.5 12C7.5 16.5 12 22 12 22C12 22 16.5 16.5 16.5 12C16.5 7.5 12 2 12 2Z"
            stroke="#d6b9ab"
            stroke-width="0.9"></path>
          <path
            d="M2 12C2 12 7.5 7.5 12 7.5C16.5 7.5 22 12 22 12C22 12 16.5 16.5 12 16.5C7.5 16.5 2 12 2 12Z"
            stroke="#d6b9ab"
            stroke-width="0.9"></path>
        </svg>
        <span class={heroTaglineClasses}>L U X E &nbsp;&nbsp; F E A S T</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 2C12 2 7.5 7.5 7.5 12C7.5 16.5 12 22 12 22C12 22 16.5 16.5 16.5 12C16.5 7.5 12 2 12 2Z"
            stroke="#d6b9ab"
            stroke-width="0.9"></path>
          <path
            d="M2 12C2 12 7.5 7.5 12 7.5C16.5 7.5 22 12 22 12C22 12 16.5 16.5 12 16.5C7.5 16.5 2 12 2 12Z"
            stroke="#d6b9ab"
            stroke-width="0.9"></path>
        </svg>
        <span class={heroOrnamentLineClasses} style="background: linear-gradient(to left, transparent, var(--blush));"></span>
      </div>

      <p class={heroDescriptionClasses}>
        Crafting unforgettable culinary experiences for weddings,<br />
        corporate milestones &amp; intimate celebrations across India.
      </p>

      <div class={heroActionsClasses}>
        <Button href="#">Begin Your Journey</Button>
        <Button variant="ghost" href="#services">Explore Services</Button>
      </div>
    </div>

    <div class={heroScrollHintClasses}>
      <span class={scrollLineClasses}></span>
      <span>Scroll</span>
    </div>

    <button
      class={muteButtonClasses}
      id="muteBtn"
      onclick="toggleMute()"
      title="Toggle sound"
      aria-label="Toggle video sound"
    >
      <svg
        id="iconMuted"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
      >
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <line x1="23" y1="9" x2="17" y2="15"></line>
        <line x1="17" y1="9" x2="23" y2="15"></line>
      </svg>
      <svg
        id="iconSound"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        style="display:none"
      >
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
      </svg>
    </button>
  </section>
