---
import Button from '@/components/ui/Button.astro';

const galleryTiles = [
  {
    title: 'Wedding Feast',
    imageUrl: '/images/gallery/elamrit-gallery-wedding-feast.png',
    tileClass: 'relative min-h-[280px] overflow-hidden bg-[var(--bg-gallery-tile)] md:col-span-2 lg:col-span-1 lg:row-span-2 lg:min-h-0',
  },
  {
    title: 'Artisan Plating',
    imageUrl: '/images/gallery/elamrit-gallery-artisan-plating.png',
    tileClass: 'relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0',
  },
  {
    title: 'Live Station',
    imageUrl: '/images/gallery/elamrit-gallery-live-station.png',
    tileClass: 'relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0',
  },
  {
    title: 'Corporate Event',
    imageUrl: '/images/gallery/elamrit-gallery-corporate-event.png',
    tileClass: 'relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0',
  },
  {
    title: 'Private Dining',
    imageUrl: '/images/gallery/elamrit-gallery-private-dining.png',
    tileClass: 'relative min-h-[200px] overflow-hidden bg-[var(--bg-gallery-tile)] lg:min-h-0',
  },
] as const;

const galleryBgClasses =
  'block h-full w-full bg-cover bg-center transition-transform duration-500 ease-out group-hover:scale-[1.04]';
---
  <section id="gallery" class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]">
    <div class="mb-12 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <h2 class="max-w-[380px] font-serif text-[clamp(28px,3vw,42px)] font-light leading-snug text-dark-brown">
        A Taste of What <em class="italic text-dark-red">We Create</em>
      </h2>
      <Button href="/gallery" variant="linkDarkRed">View Full Gallery</Button>
    </div>
    <div
      class="grid grid-cols-1 gap-1.5 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr] lg:grid-rows-[260px_260px]"
    >
      {
        galleryTiles.map((tile) => (
          <div class:list={['group', tile.tileClass]}>
            <div
              class={galleryBgClasses}
              style={`background-image: url('${tile.imageUrl}'); filter: saturate(0.7) brightness(0.8);`}
            ></div>
            <div
              class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,rgba(36,33,31,0.6)_0%,transparent_60%)]"
            ></div>
            <span class="absolute bottom-4 left-[18px] font-body text-[10px] tracking-[0.2em] text-cream/60 uppercase">
              {tile.title}
            </span>
          </div>
        ))
      }
    </div>
  </section>
