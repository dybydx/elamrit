---
import Card from '@/components/ui/Card.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
---
  <section
    id="services"
    class="px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]"
    style="background: var(--bg-services-home)"
  >
    <SectionHeader class="mb-16" label="What We Do" align="center" showDivider={true}>
      Curated Services for <em>Every Occasion</em>
    </SectionHeader>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4 lg:gap-[18px]">
      <Card variant="service">
        <span
          class="mb-5 block font-display text-[clamp(44px,4.8vw,56px)] leading-[0.95] font-normal tracking-[0.14em] text-dark-red"
          >01</span
        >
        <svg
          class="mb-6 h-[clamp(44px,4.5vw,52px)] w-[clamp(44px,4.5vw,52px)] text-gray-orange opacity-[0.85]"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.2"
        >
          <path d="M20 4C20 4 8 12 8 22C8 28.6 13.4 34 20 34C26.6 34 32 28.6 32 22C32 12 20 4 20 4Z"></path>
          <path d="M20 14V34M14 20L20 14L26 20"></path>
        </svg>
        <h3
          class="mb-4 font-serif text-[clamp(22px,2.15vw,28px)] leading-snug font-normal text-dark-brown"
        >
          Wedding Catering
        </h3>
        <p
          class="mb-7 font-body text-[clamp(15px,1.35vw,17px)] leading-[1.75] text-[var(--text-muted-on-cream)]"
        >
          From grand Hindu ceremonies to intimate destination weddings, we orchestrate culinary narratives that honour
          your most significant celebration.
        </p>
        <span
          class="service-link flex items-center gap-2 font-body text-[clamp(11px,0.95vw,12px)] tracking-[0.22em] text-dark-red uppercase transition-colors group-hover:text-gray-orange"
          >Explore Weddings</span
        >
      </Card>
      <Card variant="service">
        <span
          class="mb-5 block font-display text-[clamp(44px,4.8vw,56px)] leading-[0.95] font-normal tracking-[0.14em] text-dark-red"
          >02</span
        >
        <svg
          class="mb-6 h-[clamp(44px,4.5vw,52px)] w-[clamp(44px,4.5vw,52px)] text-gray-orange opacity-[0.85]"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.2"
        >
          <rect x="6" y="10" width="28" height="22" rx="1"></rect>
          <path d="M14 10V8M26 10V8"></path>
          <path d="M6 16h28"></path>
          <path d="M14 22h4M22 22h4M14 27h4"></path>
        </svg>
        <h3
          class="mb-4 font-serif text-[clamp(22px,2.15vw,28px)] leading-snug font-normal text-dark-brown"
        >
          Corporate Catering
        </h3>
        <p
          class="mb-7 font-body text-[clamp(15px,1.35vw,17px)] leading-[1.75] text-[var(--text-muted-on-cream)]"
        >
          Board meetings, product launches, annual galas — premium catering solutions that reflect your organisation's
          stature and ambition.
        </p>
        <span
          class="service-link flex items-center gap-2 font-body text-[clamp(11px,0.95vw,12px)] tracking-[0.22em] text-dark-red uppercase transition-colors group-hover:text-gray-orange"
          >Corporate Services</span
        >
      </Card>
      <Card variant="service">
        <span
          class="mb-5 block font-display text-[clamp(44px,4.8vw,56px)] leading-[0.95] font-normal tracking-[0.14em] text-dark-red"
          >03</span
        >
        <svg
          class="mb-6 h-[clamp(44px,4.5vw,52px)] w-[clamp(44px,4.5vw,52px)] text-gray-orange opacity-[0.85]"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.2"
        >
          <circle cx="20" cy="20" r="14"></circle>
          <path d="M20 10v10l7 4"></path>
          <path d="M10 20h4M26 20h4M20 10v4M20 26v4"></path>
        </svg>
        <h3
          class="mb-4 font-serif text-[clamp(22px,2.15vw,28px)] leading-snug font-normal text-dark-brown"
        >
          Social Celebrations
        </h3>
        <p
          class="mb-7 font-body text-[clamp(15px,1.35vw,17px)] leading-[1.75] text-[var(--text-muted-on-cream)]"
        >
          Birthdays, anniversaries, cocktail evenings — turning everyday milestones into extraordinary memories through
          food and experience.
        </p>
        <span
          class="service-link flex items-center gap-2 font-body text-[clamp(11px,0.95vw,12px)] tracking-[0.22em] text-dark-red uppercase transition-colors group-hover:text-gray-orange"
          >Social Events</span
        >
      </Card>
      <Card variant="service">
        <span
          class="mb-5 block font-display text-[clamp(44px,4.8vw,56px)] leading-[0.95] font-normal tracking-[0.14em] text-dark-red"
          >04</span
        >
        <svg
          class="mb-6 h-[clamp(44px,4.5vw,52px)] w-[clamp(44px,4.5vw,52px)] text-gray-orange opacity-[0.85]"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.2"
        >
          <path d="M8 32C8 32 10 16 20 10C30 16 32 32 32 32"></path>
          <path d="M14 26C14 26 16 20 20 18C24 20 26 26 26 26"></path>
          <line x1="8" y1="32" x2="32" y2="32"></line>
        </svg>
        <h3
          class="mb-4 font-serif text-[clamp(22px,2.15vw,28px)] leading-snug font-normal text-dark-brown"
        >
          Private Dining
        </h3>
        <p
          class="mb-7 font-body text-[clamp(15px,1.35vw,17px)] leading-[1.75] text-[var(--text-muted-on-cream)]"
        >
          Bespoke in-home dining experiences. A personal chef, curated menu, and impeccable service — all within the
          intimacy of your space.
        </p>
        <span
          class="service-link flex items-center gap-2 font-body text-[clamp(11px,0.95vw,12px)] tracking-[0.22em] text-dark-red uppercase transition-colors group-hover:text-gray-orange"
          >Private Dining</span
        >
      </Card>
    </div>
  </section>
