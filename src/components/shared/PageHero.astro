---
export type PageHeroVariant = 'split' | 'center';

type BreadcrumbItem = { label: string; href?: string };

export interface Props {
  variant?: PageHeroVariant;
  id?: string;
  class?: string;

  breadcrumb?: BreadcrumbItem[];

  title?: string;
  titleHtml?: string;
  description?: string;

  backgroundClass?: string;

  imageClass?: string;
  quote?: string;
  quoteAttribution?: string;

  /** Extra classes for the description paragraph (e.g. `max-w-none w-full` for full column width). */
  descriptionClass?: string;
}

const {
  variant = 'split',
  id = 'page-hero',
  class: className,
  breadcrumb,
  title,
  titleHtml,
  description,
  backgroundClass = 'bg-dark-red',
  imageClass,
  quote,
  quoteAttribution,
  descriptionClass,
} = Astro.props;

const splitDescriptionClasses = descriptionClass ?? 'max-w-[400px]';
const centerDescriptionClasses = descriptionClass ?? 'mx-auto max-w-[620px]';
const descriptionBase =
  'font-serif text-[clamp(17px,1.35vw,21px)] italic leading-[1.7] text-cream/75';

const hasRightPane = variant === 'split' && (imageClass || quote || quoteAttribution);
---

{variant === 'split' ? (
  <section
    id={id}
    class:list={[
      'relative grid min-h-[70vh] w-full grid-cols-1 overflow-hidden pt-[var(--nav-h)] lg:grid-cols-2',
      backgroundClass,
      className,
    ]}
  >
    <div class="relative z-[2] flex flex-col justify-end px-5 pb-20 pt-12 md:px-10 md:pb-20 md:pl-20 lg:py-20 lg:pl-20 lg:pr-[60px]">
      {breadcrumb?.length ? (
        <div class="mb-7 flex items-center gap-2.5 font-body text-xs tracking-[0.26em] text-blush uppercase">
          {breadcrumb.map((item, idx) => (
            <>
              {idx > 0 ? <span class="opacity-40">/</span> : null}
              {item.href ? (
                <a class="text-gray-orange transition-colors hover:text-cream" href={item.href}>
                  {item.label}
                </a>
              ) : (
                <span class="text-cream">{item.label}</span>
              )}
            </>
          ))}
        </div>
      ) : null}

      {titleHtml ? (
        <h1
          class="mb-4 font-display text-[clamp(38px,5vw,72px)] leading-[1.05] tracking-[0.32em] text-cream uppercase"
          set:html={titleHtml}
        />
      ) : title ? (
        <h1 class="mb-4 font-display text-[clamp(38px,5vw,72px)] leading-[1.05] tracking-[0.32em] text-cream uppercase">
          {title}
        </h1>
      ) : null}

      {description ? (
        <p class:list={[descriptionBase, splitDescriptionClasses]}>{description}</p>
      ) : null}

      <slot />
    </div>

    {hasRightPane ? (
      <div class="relative hidden overflow-hidden lg:block">
        {imageClass ? <div class:list={[imageClass, 'absolute inset-0 min-h-[50vh] lg:min-h-full']} /> : null}

        {quote ? (
          <div
            class="absolute right-[60px] bottom-[60px] z-[3] max-w-[280px] border-l-[3px] border-green bg-[color-mix(in_srgb,var(--dark-red)_92%,black)] px-8 py-7 backdrop-blur-md"
          >
            <p class="mb-3 font-serif text-lg italic leading-[1.65] text-cream">"{quote}"</p>
            {quoteAttribution ? (
              <div class="font-body text-xs tracking-[0.18em] text-gray-orange uppercase">
                — {quoteAttribution}
              </div>
            ) : null}
          </div>
        ) : null}
      </div>
    ) : null}
  </section>
) : (
  <section
    id={id}
    class:list={[
      'relative flex min-h-[60vh] w-full flex-col items-center justify-center overflow-hidden px-5 pt-[var(--nav-h)] text-center md:px-10 lg:px-20',
      backgroundClass,
      className,
    ]}
  >
    {breadcrumb?.length ? (
      <div class="mb-7 flex items-center justify-center gap-2.5 font-body text-xs tracking-[0.26em] text-blush uppercase">
        {breadcrumb.map((item, idx) => (
          <>
            {idx > 0 ? <span class="opacity-40">/</span> : null}
            {item.href ? (
              <a class="text-gray-orange transition-colors hover:text-cream" href={item.href}>
                {item.label}
              </a>
            ) : (
              <span class="text-cream">{item.label}</span>
            )}
          </>
        ))}
      </div>
    ) : null}

    {titleHtml ? (
      <h1
        class="mb-4 font-display text-[clamp(36px,4.9vw,64px)] leading-[1.05] tracking-[0.3em] text-cream uppercase"
        set:html={titleHtml}
      />
    ) : title ? (
      <h1 class="mb-4 font-display text-[clamp(36px,4.9vw,64px)] leading-[1.05] tracking-[0.3em] text-cream uppercase">
        {title}
      </h1>
    ) : null}

    {description ? (
      <p class:list={[descriptionBase, centerDescriptionClasses]}>{description}</p>
    ) : null}

    <slot />
  </section>
)}

