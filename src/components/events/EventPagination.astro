---
interface Props {
  currentPage: number;
  totalPages: number;
}

const { currentPage, totalPages } = Astro.props;
---

{
  totalPages > 1 ? (
    <nav
      class="mx-auto mt-14 flex max-w-[1100px] flex-wrap items-center justify-center gap-4 border-t border-[rgba(189,148,118,0.28)] pt-10"
      aria-label="Events pagination"
    >
      {currentPage > 1 ? (
        <a
          href={currentPage === 2 ? '/events' : `/events/page/${currentPage - 1}`}
          class="font-body text-[14px] tracking-[0.14em] text-dark-red uppercase transition-colors hover:text-gray-orange"
        >
          ← Newer events
        </a>
      ) : (
        <span class="font-body text-[14px] tracking-[0.14em] text-[var(--text-muted-on-cream-soft)] uppercase">
          ← Newer events
        </span>
      )}
      <span class="font-body text-[15px] text-[var(--text-muted-on-cream)]">
        Page {currentPage} of {totalPages}
      </span>
      {currentPage < totalPages ? (
        <a
          href={`/events/page/${currentPage + 1}`}
          class="font-body text-[14px] tracking-[0.14em] text-dark-red uppercase transition-colors hover:text-gray-orange"
        >
          Older events →
        </a>
      ) : (
        <span class="font-body text-[14px] tracking-[0.14em] text-[var(--text-muted-on-cream-soft)] uppercase">
          Older events →
        </span>
      )}
    </nav>
  ) : null
}
