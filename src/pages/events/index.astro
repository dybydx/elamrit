---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import EventPostGrid from '@/components/events/EventPostGrid.astro';
import EventPagination from '@/components/events/EventPagination.astro';
import {
  EVENT_PAGE_SIZE,
  eventsHubHero,
  sliceEventPage,
  sortEventEntries,
  totalEventPages,
} from '@/lib/events';

const all = await getCollection('events');
const sorted = sortEventEntries(all);
const page = 1;
const events = sliceEventPage(sorted, page, EVENT_PAGE_SIZE);
const totalPages = totalEventPages(sorted.length);
---

<BaseLayout
  title="Events — Elamrit Luxe Feast"
  description="Selected programmes and celebrations we have catered — format notes, pacing, and how the table supported the room."
  bottomCta="about"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    class="!min-h-[48vh] lg:!min-h-[54vh]"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Journal', href: '/journal' },
      { label: 'Events' },
    ]}
    titleHtml="EVENTS"
    description="Short write-ups of real programmes — what the brief asked for, how service and menu worked together, and what we would repeat on the next floor."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={eventsHubHero}
    quote="Every room has a rhythm; our job is to feed it without stealing the spotlight."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Get a Quote</Button>
      <Button href="/journal" variant="outlineCream">Journal hub</Button>
    </div>
  </PageHero>

  <section class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]">
    <div class="mx-auto mb-14 max-w-[680px] text-center">
      <div class="mb-4 flex justify-center">
        <SectionEyebrow>Showcases</SectionEyebrow>
      </div>
      <p class="font-body text-[17px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Events are dated snapshots — newest first. They complement longer articles on the blog; together they live under Journal.
      </p>
    </div>

    <SectionHeader class="mb-4" label="Latest" align="center" showDivider={true}>
      On the <em>floor</em>
    </SectionHeader>
    <p class="mx-auto mb-12 max-w-[1100px] text-center font-body text-[15px] leading-relaxed text-[var(--text-muted-on-cream)]">
      {sorted.length} event{sorted.length === 1 ? '' : 's'}
      {
        totalPages > 1 ? (
          <>
            {' '}
            · {events.length} on this page ·{' '}
            <a
              href="/events/page/2"
              class="text-dark-red underline decoration-dark-red/30 underline-offset-4 transition-colors hover:text-gray-orange hover:decoration-gray-orange/50"
            >
              Older events →
            </a>
          </>
        ) : null
      }
    </p>
    <EventPostGrid events={events} startIndex={0} />
    <EventPagination currentPage={page} totalPages={totalPages} />
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
