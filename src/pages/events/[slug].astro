---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import RelatedBlogCards from '@/components/journal/RelatedBlogCards.astro';
import RelatedEventCards from '@/components/journal/RelatedEventCards.astro';
import { formatEventDate } from '@/lib/events';
import { relatedBlogPostsByTag, relatedEventsExcluding } from '@/lib/journal-related';

export async function getStaticPaths() {
  const items = await getCollection('events');
  return items.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allBlog = await getCollection('blog');
const allEvents = await getCollection('events');
const relatedEvents = relatedEventsExcluding(allEvents, entry.id, entry.data.tag);
const relatedBlogs = relatedBlogPostsByTag(allBlog, entry.data.tag);
const showRelated = relatedBlogs.length > 0 || relatedEvents.length > 0;

const metaLine = [
  formatEventDate(entry.data.eventAt),
  entry.data.tag,
  entry.data.location,
]
  .filter(Boolean)
  .join(' · ');

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Journal', href: '/journal' },
  { label: 'Events', href: '/events' },
  {
    label: entry.data.breadcrumbTitle,
    title: entry.data.title,
  },
];

const title = `${entry.data.title} — Elamrit Events`;
const description = entry.data.excerpt;
---

<BaseLayout
  {title}
  {description}
  bottomCta="about"
  ogType="article"
  image={entry.data.heroImageSrc}
  article={{
    headline: entry.data.title,
    datePublished: entry.data.eventAt,
    section: entry.data.tag,
  }}
>
  <Nav variant="solid" />

  <PageHero
    variant="article"
    breadcrumb={breadcrumb}
    title={entry.data.title}
    description={metaLine}
    imageClass="ph-image"
    heroImageSrc={entry.data.heroImageSrc}
    quote={entry.data.quote}
    quoteAttribution={entry.data.quoteAttribution}
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Get a Quote</Button>
      <Button href="/events" variant="outlineCream">All events</Button>
    </div>
  </PageHero>

  <article class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]">
    <div class="blog-prose mx-auto max-w-[720px]">
      <p class="mb-12 font-body text-[17px] leading-[1.85] text-[var(--text-muted-on-cream)]">{entry.data.excerpt}</p>
      <Content />
    </div>

    {
      showRelated ? (
        <>
          {relatedEvents.length > 0 ? (
            <section class="journal-related-band">
              <div class="mx-auto w-full max-w-[1100px]">
                <SectionHeader class="mb-8" label="Events" align="center" showDivider={true}>
                  Related <em>showcases</em>
                </SectionHeader>
                <RelatedEventCards events={relatedEvents} />
              </div>
            </section>
          ) : null}
          {relatedBlogs.length > 0 ? (
            relatedEvents.length > 0 ? (
              <div class="mx-auto mt-16 w-full max-w-[1100px] border-t border-[rgba(189,148,118,0.28)] pt-16">
                <SectionHeader class="mb-8" label="Blog" align="center" showDivider={true}>
                  Related <em>articles</em>
                </SectionHeader>
                <RelatedBlogCards posts={relatedBlogs} />
              </div>
            ) : (
              <section class="journal-related-band">
                <div class="mx-auto w-full max-w-[1100px]">
                  <SectionHeader class="mb-8" label="Blog" align="center" showDivider={true}>
                    Related <em>articles</em>
                  </SectionHeader>
                  <RelatedBlogCards posts={relatedBlogs} />
                </div>
              </section>
            )
          ) : null}
        </>
      ) : null
    }

    <div class="mx-auto mt-16 flex max-w-[720px] flex-wrap justify-between gap-4 border-t border-[rgba(189,148,118,0.28)] pt-10">
      <Button href="/events" variant="outlineCta">← Back to events</Button>
      <Button href="/blog" variant="outlineCta">Read the blog</Button>
    </div>
  </article>

  <SiteFooter slot="footer" />
</BaseLayout>
