---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/shared/Nav.astro';
import Hero from '../components/home/hero/Hero.astro';
import Marquee from '../components/home/hero/Marquee.astro';
import BrandIntro from '../components/home/brand/BrandIntro.astro';
import Services from '../components/home/services/Services.astro';
import Gallery from '../components/home/showcase/Gallery.astro';
import Experience from '../components/home/showcase/Experience.astro';
import SectionBreak from '../components/home/brand/SectionBreak.astro';
import FoodJunction from '../components/home/services/FoodJunction.astro';
import Clients from '../components/home/showcase/Clients.astro';
import Testimonials from '../components/home/showcase/Testimonials.astro';
import CtaSection from '../components/home/cta/CtaSection.astro';
import Footer from '../components/home/cta/Footer.astro';
---

<BaseLayout
  title="Elamrit — Luxe Feast | Premium Catering Pune & Pan India"
  description="Elamrit crafts unforgettable culinary experiences for weddings, corporate events, and social celebrations. Premium luxury catering across Pune and Pan India."
>
  <Nav />
  <Hero />
  <Marquee />
  <BrandIntro />
  <Services />
  <Gallery />
  <Experience />
  <SectionBreak />
  <FoodJunction />
  <Clients />
  <Testimonials />
  <CtaSection />
  <Footer />
</BaseLayout>

<script is:inline>
  (function () {
    function initNavScroll() {
      const nav = document.getElementById('mainNav');
      if (!nav || nav.getAttribute('data-nav-variant') !== 'hero') return;
      const onScroll = () => {
        if (window.scrollY > 60) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    window.toggleMute = function toggleMute() {
      const video = document.getElementById('heroVideo');
      const muteBtn = document.getElementById('muteBtn');
      const iconMuted = document.getElementById('iconMuted');
      const iconSound = document.getElementById('iconSound');
      if (!video || !muteBtn || !iconMuted || !iconSound) return;
      video.muted = !video.muted;
      if (video.muted) {
        iconMuted.style.display = 'block';
        iconSound.style.display = 'none';
        muteBtn.classList.remove('unmuted');
      } else {
        iconMuted.style.display = 'none';
        iconSound.style.display = 'block';
        muteBtn.classList.add('unmuted');
      }
    };

    document.addEventListener('DOMContentLoaded', initNavScroll);
  })();
</script>
