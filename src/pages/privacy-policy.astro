---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/shared/Nav.astro';
import PageHero from '../components/shared/PageHero.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
---

<BaseLayout
  title="Privacy Policy — Elamrit Luxe Feast"
  description="Elamrit Luxe Feast privacy policy covering how we collect, use, and protect information shared through our website."
>
  <Nav variant="solid" />

  <PageHero
    variant="center"
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }]}
    titleHtml="PRIVACY<br />POLICY"
    description="A clear view of how we handle your information — with restraint, respect, and purpose."
    descriptionClass="mx-auto max-w-[760px]"
  />

  <main class="bg-cream px-5 py-16 md:px-10 lg:px-20 lg:py-24">
    <div class="mx-auto w-full max-w-[920px]">
      <div class="prose max-w-none">
        <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
          This policy is a placeholder for now and will be updated with Elamrit’s official legal text. If you have
          questions, contact us at <a class="text-dark-red underline underline-offset-4" href="mailto:hello@elamrit.example">hello@elamrit.example</a>.
        </p>

        <section class="mt-10">
          <h2 class="font-serif text-[26px] font-light leading-tight text-dark-brown">Information we collect</h2>
          <p class="mt-3 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
            When you reach out (e.g. “Get a Quote”), you may share details such as your name, contact information, event
            date, city, guest count, and preferences.
          </p>
        </section>

        <section class="mt-10">
          <h2 class="font-serif text-[26px] font-light leading-tight text-dark-brown">How we use information</h2>
          <p class="mt-3 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
            We use your information to respond to enquiries, prepare proposals, coordinate event planning, and improve
            our service experience.
          </p>
        </section>

        <section class="mt-10">
          <h2 class="font-serif text-[26px] font-light leading-tight text-dark-brown">Cookies & analytics</h2>
          <p class="mt-3 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
            We may use standard analytics and cookies to understand site usage and improve performance. Where required,
            we will implement consent controls.
          </p>
        </section>

        <section class="mt-10">
          <h2 class="font-serif text-[26px] font-light leading-tight text-dark-brown">Data retention</h2>
          <p class="mt-3 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
            We retain information for as long as needed to fulfil the purposes described above, or as required by law.
          </p>
        </section>

        <section class="mt-10">
          <h2 class="font-serif text-[26px] font-light leading-tight text-dark-brown">Your choices</h2>
          <p class="mt-3 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
            You may request access, correction, or deletion of your information by contacting us.
          </p>
        </section>
      </div>
    </div>
  </main>

  <SiteFooter slot="footer" />
</BaseLayout>

