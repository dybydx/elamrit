---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import MenuPhotoCard from '@/components/menus/MenuPhotoCard.astro';
import { foodJunctionMenusHero } from '@/lib/hero-images';
---

<BaseLayout
  title="Menus — Food Junction"
  description="Corporate event menus by Food Junction — Indian, international, fusion, desserts, and beverages. Explore cuisine directions and build a brief for your business programme."
  bottomCta="home"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Food Junction', href: '/food-junction' },
      { label: 'Menus' },
    ]}
    titleHtml="CORPORATE<br />MENUS"
    description="Menus designed for diverse guest lists, dietary clarity, and service formats that work in ballrooms, convention centres, and headquarters — not only in banquet templates."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={foodJunctionMenusHero}
    quote="A corporate menu should make every delegate feel considered — including the ones who did not RSVP their dietary needs."
    quoteAttribution="Food Junction"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/menus/custom-menu" variant="creamOnDark">Menu builder</Button>
      <Button href="/food-junction/get-a-quote" variant="outlineCream">Get a Quote</Button>
    </div>
  </PageHero>

  <section class="bg-cream px-5 py-20 md:px-10 lg:px-20 lg:py-[100px]">
    <div class="mx-auto mb-14 max-w-[720px] text-center">
      <div class="mb-4 flex justify-center">
        <SectionEyebrow>How we work</SectionEyebrow>
      </div>
      <h2 class="mb-5 font-serif text-[clamp(26px,3vw,36px)] font-light text-dark-brown">
        Cuisine breadth, <em class="italic text-dark-red">corporate clarity</em>
      </h2>
      <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
        We combine regional Indian favourites with international comfort and fusion where it fits your audience. Every
        proposal includes Jain, vegetarian, and non-vegetarian lanes where required — labelled clearly for your comms
        team.
      </p>
    </div>

    <div class="mx-auto grid max-w-[1200px] grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <MenuPhotoCard
        href="/menus/indian-cuisine"
        number="01"
        title="Indian"
        description="Regional thalis, celebratory mains, and crowd-pleasing classics for mixed delegations."
        linkLabel="Explore Indian"
        imageSrc="/images/menus/menu-card-indian.png"
        imageAlt="Indian catering menu card — Elamrit Food Junction corporate events."
      />
      <MenuPhotoCard
        href="/menus/international-cuisine"
        number="02"
        title="International"
        description="Continental and global formats that travel well from buffet to plated service."
        linkLabel="Explore International"
        imageSrc="/images/menus/menu-card-international.png"
        imageAlt="International cuisine menu card — Food Junction corporate catering."
      />
      <MenuPhotoCard
        href="/menus/fusion-cuisine"
        number="03"
        title="Fusion"
        description="When your brand story calls for something less traditional — without losing discipline in execution."
        linkLabel="Explore Fusion"
        imageSrc="/images/menus/menu-card-fusion.png"
        imageAlt="Fusion cuisine menu card — Food Junction."
      />
      <MenuPhotoCard
        href="/menus/desserts"
        number="04"
        title="Desserts"
        description="Finishes that work for high-throughput service and seated finales alike."
        linkLabel="Explore Desserts"
        imageSrc="/images/menus/menu-card-desserts.png"
        imageAlt="Desserts menu card — Food Junction corporate events."
      />
      <MenuPhotoCard
        href="/menus/beverages"
        number="05"
        title="Beverages"
        description="Coffee programmes, mocktails, and bar service structured around your schedule."
        linkLabel="Explore Beverages"
        imageSrc="/images/menus/menu-card-beverages.png"
        imageAlt="Beverages menu card — Food Junction."
      />
      <a href="/menus/custom-menu" class="group block">
        <Card variant="service" class="h-full min-h-[280px]">
          <span class="mb-4 block font-display text-[36px] text-dark-red">+</span>
          <h3 class="mb-3 font-serif text-[22px] font-normal text-dark-brown">Fully custom</h3>
          <p class="mb-6 font-body text-[16px] leading-[1.75] text-[var(--text-muted-on-cream)]">
            Share your brief — audience, city, format, and must-have dishes. We respond with a structured direction.
          </p>
          <span
            class="font-body text-[12px] tracking-[0.2em] text-dark-red uppercase transition-colors group-hover:text-gray-orange"
            >Open custom menu builder →</span
          >
        </Card>
      </a>
    </div>

    <div class="mx-auto mt-16 max-w-[640px] text-center">
      <p class="font-body text-[16px] leading-[1.75] text-[var(--text-muted-on-cream)]">
        These categories mirror the main Elamrit menu library — shared kitchen standards, Food Junction packaging for
        corporate programmes.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/menus" variant="outlineCta">All Elamrit menus</Button>
        <Button href="/food-junction/services" variant="outlineCta">Back to services</Button>
      </div>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
