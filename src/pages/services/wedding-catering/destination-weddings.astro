---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import ChildServiceHero from '@/components/services/ChildServiceHero.astro';
import ServiceStatsStrip from '@/components/services/ServiceStatsStrip.astro';
import ServiceWhatYouGet from '@/components/services/ServiceWhatYouGet.astro';
import Testimonials from '@/components/home/showcase/Testimonials.astro';
---

<BaseLayout
  title="Destination Wedding Catering — Elamrit Luxe Feast"
  description="Destination wedding catering with travel-ready operations, vendor coordination, and consistent quality — in any city, any venue, by Elamrit Luxe Feast."
  bottomCta="about"
>
  <Nav variant="solid" />

  <ChildServiceHero
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Wedding Catering', href: '/services/wedding-catering' },
      { label: 'Destination Weddings' },
    ]}
    titleHtml="DESTINATION<br />WEDDINGS"
    description="New city, new venue, same standard — composed execution that travels beautifully."
    primaryCtaHref="/contact/get-a-quote"
    primaryCtaLabel="Get a Quote"
    secondaryCtaHref="/services/pan-india-catering"
    secondaryCtaLabel="Pan India Catering"
  />

  <!-- Story section -->
  <section
    id="destination-story"
    class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]"
  >
    <div>
      <SectionEyebrow class="mb-4">Travel-Ready Operations</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Logistics that feel <em class="italic text-dark-red">invisible</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Destination weddings are won backstage — transport, sourcing, prep, staffing, and timing. We build a plan that keeps food quality consistent and service calm, even when the venue is hundreds of kilometres from our base.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The best on-site catering looks effortless. The effort is what travels with us."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We've catered destination weddings in Rajasthan, Goa, Kerala, and beyond — each time with the same meticulous prep that defines every event we touch.
      </p>
    </div>
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Any City · Any Venue
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section id="destination-pillars" class="px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]" style="background: var(--bg-philosophy)">
    <div class="mb-16 grid grid-cols-1 items-end gap-6 md:mb-20 lg:grid-cols-[1fr_2fr] lg:gap-[60px]">
      <h2 class="font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        How We <em class="italic text-dark-red">Prepare</em>
      </h2>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We treat destination weddings as a project — not an event. The planning starts weeks before the date and every detail is locked before we travel.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-0.5 lg:grid-cols-3">
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">01</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <rect x="8" y="10" width="28" height="24" rx="1" />
          <path d="M16 10V7M28 10V7" />
          <path d="M8 18h28" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Pre-travel Planning</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Vendor briefings, kitchen walkthroughs, service rehearsals, and supply chain mapping — all done before the team departs from Pune.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">02</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="22" cy="22" r="16" />
          <path d="M22 8v8M22 28v8M8 22h8M28 22h8" />
          <circle cx="22" cy="22" r="4" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">On-ground Execution</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          A dedicated on-site lead coordinates the full team — from kitchen to front-of-house — ensuring quality and timing stay consistent across every function.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">03</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M10 34C10 34 12 20 22 14C32 20 34 34 34 34" />
          <path d="M16 28C16 28 18 22 22 20C26 22 28 28 28 28" />
          <line x1="10" y1="34" x2="34" y2="34" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Consistent Quality</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Same sourcing standards, same presentation, same service warmth — whether we're operating in Pune or Udaipur. Distance doesn't dilute the standard.
        </p>
      </Card>
    </div>
  </section>

  <ServiceStatsStrip
    items={[
      { label: 'Coverage', value: 'Pan India' },
      { label: 'Popular venues', value: 'Rajasthan · Goa' },
      { label: 'Team', value: 'Dedicated on-site' },
      { label: 'Scale', value: '100 – 2,000+' },
    ]}
  />

  <ServiceWhatYouGet
    titleHtml="What makes destination execution <em>calm</em>"
    description="A destination wedding succeeds when logistics are invisible. We map supply chains, venue constraints, and staffing needs early — then execute with a dedicated on-site lead so service stays consistent across every function."
    bullets={[
      'Pre-travel walkthrough + kitchen assessment',
      'Vendor coordination and sourcing plan per city',
      'Dedicated on-site operations lead',
      'Consistency checks across multiple functions',
      'Live stations and plated formats that travel well',
    ]}
    ctaHref="/contact/get-a-quote"
    ctaLabel="Plan Your Wedding"
  />

  <Testimonials />

  <SiteFooter slot="footer" />
</BaseLayout>
