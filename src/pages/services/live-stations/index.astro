---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
---

<BaseLayout
  title="Live Cooking Stations — Elamrit Luxe Feast"
  description="Live cooking stations for weddings, corporate events, and social celebrations — high energy, high aroma, and chef-led theatre by Elamrit Luxe Feast."
  bottomCta="home"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Live Stations' },
    ]}
    titleHtml="LIVE<br />STATIONS"
    description="High energy, high aroma, chef presence — live counters that become the focal point of your event."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    quote="A live station doesn't just serve food — it creates a moment guests gather around."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Add to Your Event</Button>
      <Button href="/services" variant="outlineCream">All Services</Button>
    </div>
  </PageHero>

  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div>
      <SectionEyebrow class="mb-4">Live Counter Theatre</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Food as <em class="italic text-dark-red">performance</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Live stations transform your event's energy. The sizzle of a tawa, the aroma of fresh chaat, the spectacle of a dessert being plated in front of your guests — these are moments that embed themselves in memory. We build stations that are as theatrical as they are delicious.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The queue at a well-run live station is one of the best signs your event is a success."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We design each station as its own world — countertop, chef uniform, signage, and choreography — so the visual and culinary experience are seamless.
      </p>
    </div>
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Theatre · Aroma · Craft
      </div>
    </div>
  </section>

  <!-- Station types on dark-red (experience tile style) -->
  <section class="grid grid-cols-1 items-center gap-10 bg-dark-red px-5 py-20 md:gap-20 md:px-10 lg:grid-cols-2 lg:px-20 lg:py-20">
    <div>
      <span class="mb-4 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">Station Types</span>
      <h2 class="font-serif text-[clamp(30px,3.5vw,48px)] font-light leading-tight text-cream">
        A counter for <em class="italic">every occasion</em>
      </h2>
      <p class="mt-6 max-w-[440px] font-body text-xl leading-[1.85] text-cream/70">
        We design and staff stations that fit the event's energy — from high-volume sangeet chaat bars to quiet, considered dessert finales at board dinners.
      </p>
      <div class="mt-11 flex flex-wrap items-center gap-5">
        <Button href="/contact/get-a-quote" variant="cream">Add to Your Event</Button>
      </div>
    </div>
    <div class="grid grid-cols-1 gap-0.5 sm:grid-cols-2">
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">Savoury</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Chaat &amp; Pani Puri — the crowd favourite, always alive</span>
      </Card>
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">Savoury</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Tawa &amp; Grill — sizzling kebabs, rotis, and meats</span>
      </Card>
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">Sweet</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Dessert Station — plated finales and interactive sweet bars</span>
      </Card>
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">International</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Pasta, Wok &amp; Mezze — live international counters for any occasion</span>
      </Card>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
