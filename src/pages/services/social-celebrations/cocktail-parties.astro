---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import ChildServiceHero from '@/components/services/ChildServiceHero.astro';
import ServiceStatsStrip from '@/components/services/ServiceStatsStrip.astro';
import ServiceWhatYouGet from '@/components/services/ServiceWhatYouGet.astro';
import Testimonials from '@/components/home/showcase/Testimonials.astro';
import MenuGallery from '@/components/menus/MenuGallery.astro';
import { socialCocktail } from '@/lib/hero-images';
import { cocktailPartyGallery } from '@/lib/service-child-galleries';
---

<BaseLayout
  title="Cocktail Party Catering — Elamrit Luxe Feast"
  description="Cocktail party catering — roaming bites, live counters, and artful canapés designed for conversation and memorable first impressions by Elamrit Luxe Feast."
  bottomCta="home"
>
  <Nav variant="solid" />

  <ChildServiceHero
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Social Celebrations', href: '/services/social-celebrations' },
      { label: 'Cocktail Parties' },
    ]}
    titleHtml="COCKTAIL<br />PARTIES"
    heroImageSrc={socialCocktail}
    description="Roaming bites, live counters, and artful canapés — formats designed for movement, conversation, and lasting impressions."
    primaryCtaHref="/contact/get-a-quote"
    primaryCtaLabel="Get a Quote"
    secondaryCtaHref="/services/social-celebrations"
    secondaryCtaLabel="All Social Services"
  />

  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div>
      <SectionEyebrow class="mb-4">Cocktail Catering</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Food that <em class="italic text-dark-red">keeps the energy flowing</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Cocktail parties live or die on their flow. The food needs to be beautiful, easy to eat while standing, and varied enough to keep guests grazing and exploring. We design cocktail menus as a journey — arrival bites, mid-evening stations, and a sweet farewell.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The best cocktail canapé is the one that gives the guest a reason to stay in the conversation."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We coordinate serving rhythm, station placement, and replenishment to keep the energy consistent from the first arrival to the last guest.
      </p>
    </div>
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
    </div>
  </section>

  <section class="px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]" style="background: var(--bg-philosophy)">
    <div class="mb-16 grid grid-cols-1 items-end gap-6 md:mb-20 lg:grid-cols-[1fr_2fr] lg:gap-[60px]">
      <h2 class="font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        The <em class="italic text-dark-red">Cocktail Formula</em>
      </h2>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Three layers of service — roaming, stationed, and finishing — that keep guests engaged from arrival to departure.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-0.5 lg:grid-cols-3">
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">01</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M22 6C22 6 8 14 8 26C8 33.7 14.3 40 22 40C29.7 40 36 33.7 36 26C36 14 22 6 22 6Z" />
          <path d="M22 16V32M16 24L22 16L28 24" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Roaming Canapés</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Elegant passed bites that meet guests where they are — artful, bite-sized, and varied enough to surprise across three passes.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">02</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="22" cy="22" r="16" />
          <path d="M22 8v8M22 28v8M8 22h8M28 22h8" />
          <circle cx="22" cy="22" r="4" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Live Stations</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Focal points that create energy and give guests something to gather around — chaat, grill, cheese, and dessert counters.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">03</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M10 34C10 34 12 20 22 14C32 20 34 34 34 34" />
          <path d="M16 28C16 28 18 22 22 20C26 22 28 28 28 28" />
          <line x1="10" y1="34" x2="34" y2="34" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Sweet Finale</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          A dessert moment — plated, passed, or stationed — that gives guests a graceful, memorable close to the evening.
        </p>
      </Card>
    </div>
  </section>

  <MenuGallery
    label={cocktailPartyGallery.label}
    tile1={cocktailPartyGallery.tile1}
    tile2={cocktailPartyGallery.tile2}
    tile3={cocktailPartyGallery.tile3}
  />

  <ServiceStatsStrip
    items={[
      { label: 'Scale', value: '30 – 400' },
      { label: 'Format', value: 'Roaming & Live' },
      { label: 'Duration', value: '2 – 4 hours' },
      { label: 'Venue', value: 'Home or hall' },
    ]}
  />

  <ServiceWhatYouGet
    titleHtml="What makes cocktails feel <em>effortless</em>"
    description="Cocktail events need flow — the food should be beautiful, easy to eat while standing, and paced so guests keep moving, talking, and discovering."
    bullets={[
      'Roaming canapé plan across multiple passes',
      'Live stations as focal points (chaat/grill/dessert)',
      'Pacing designed around music, speeches, and mingling',
      'Thoughtful labelling and dietary coverage',
      'End-of-evening sweet finale planning',
    ]}
    ctaHref="/contact/get-a-quote"
    ctaLabel="Request a Quote"
  />

  <Testimonials />

  <SiteFooter slot="footer" />
</BaseLayout>
