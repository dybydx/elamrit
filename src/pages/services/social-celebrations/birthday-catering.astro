---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import ChildServiceHero from '@/components/services/ChildServiceHero.astro';
import ServiceStatsStrip from '@/components/services/ServiceStatsStrip.astro';
import ServiceWhatYouGet from '@/components/services/ServiceWhatYouGet.astro';
import Testimonials from '@/components/home/showcase/Testimonials.astro';
import MenuGallery from '@/components/menus/MenuGallery.astro';
import { socialBirthday } from '@/lib/hero-images';
import { birthdayGallery } from '@/lib/service-child-galleries';
---

<BaseLayout
  title="Birthday Catering — Elamrit Luxe Feast"
  description="Birthday catering for milestone celebrations — curated menus, gracious service, and formats that honour the guest of honour by Elamrit Luxe Feast."
  bottomCta="home"
>
  <Nav variant="solid" />

  <ChildServiceHero
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Social Celebrations', href: '/services/social-celebrations' },
      { label: 'Birthday Catering' },
    ]}
    titleHtml="BIRTHDAY<br />CATERING"
    heroImageSrc={socialBirthday}
    description="Milestone birthdays deserve milestone catering — menus and service that honour the person and delight every guest."
    primaryCtaHref="/contact/get-a-quote"
    primaryCtaLabel="Get a Quote"
    secondaryCtaHref="/services/social-celebrations"
    secondaryCtaLabel="All Social Services"
  />

  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div>
      <SectionEyebrow class="mb-4">Birthday Catering</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        A meal as <em class="italic text-dark-red">remarkable</em> as the person it's for
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Milestone birthdays — 40th, 50th, 60th, 80th — carry meaning beyond the occasion. The food should reflect that. We work with families to design a menu and service format that feels personal, generous, and memorable.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The guest of honour should be free to celebrate — so we take care of everything else."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        From curated plated dinners for 40 to full buffet evenings for 400, we design the food experience around your family's traditions and guests' expectations.
      </p>
    </div>
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
    </div>
  </section>

  <section class="px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]" style="background: var(--bg-philosophy)">
    <div class="mb-16 grid grid-cols-1 items-end gap-6 md:mb-20 lg:grid-cols-[1fr_2fr] lg:gap-[60px]">
      <h2 class="font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        What We <em class="italic text-dark-red">Bring</em>
      </h2>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We match the scale and intimacy of your celebration — from 40 guests at a home dinner to 400 at a banquet hall.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-0.5 lg:grid-cols-3">
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">01</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M22 6C22 6 8 14 8 26C8 33.7 14.3 40 22 40C29.7 40 36 33.7 36 26C36 14 22 6 22 6Z" />
          <path d="M22 16V32M16 24L22 16L28 24" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Personalised Menus</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Favourite dishes, family recipes, and regional specialities — the menu reflects the person being celebrated, not a banquet template.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">02</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="22" cy="22" r="16" />
          <path d="M22 8v8M22 28v8M8 22h8M28 22h8" />
          <circle cx="22" cy="22" r="4" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Flexible Formats</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Plated dinners, buffet spreads, cocktail receptions, or a mix — we design the format around the occasion's energy and the guest list's age range.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">03</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M10 34C10 34 12 20 22 14C32 20 34 34 34 34" />
          <path d="M16 28C16 28 18 22 22 20C26 22 28 28 28 28" />
          <line x1="10" y1="34" x2="34" y2="34" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Dessert Moments</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          A signature dessert course or a live dessert station — the sweet finale that everyone photographs and everyone remembers.
        </p>
      </Card>
    </div>
  </section>

  <MenuGallery
    label={birthdayGallery.label}
    tile1={birthdayGallery.tile1}
    tile2={birthdayGallery.tile2}
    tile3={birthdayGallery.tile3}
  />

  <ServiceStatsStrip
    items={[
      { label: 'Scale', value: '40 – 400' },
      { label: 'Format', value: 'Plated & Buffet' },
      { label: 'Popular add-on', value: 'Live Dessert Station' },
      { label: 'Dietary', value: 'All preferences' },
    ]}
  />

  <ServiceWhatYouGet
    titleHtml="What makes birthdays feel <em>personal</em>"
    description="Birthdays are about one person — the food should reflect them. We design menus around the guest of honour and format around the guest list, so the celebration feels generous and effortless."
    bullets={[
      'Menu curation around favourites + crowd-pleasers',
      'Flexible formats: plated, buffet, cocktail, or mixed',
      'Dessert moment planning (cake + curated finale)',
      'Dietary coverage for multi-generation guest lists',
      'Staffing + service pacing so the host stays present',
    ]}
    ctaHref="/contact/get-a-quote"
    ctaLabel="Request a Quote"
  />

  <Testimonials />

  <SiteFooter slot="footer" />
</BaseLayout>
