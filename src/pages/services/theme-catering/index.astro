---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import { themeCatering } from '@/lib/hero-images';
---

<BaseLayout
  title="Theme & Concept Catering — Elamrit Luxe Feast"
  description="Theme and concept catering — curated worlds built around your occasion, with menus, service, and presentation all designed to match your vision."
  bottomCta="home"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Theme Catering' },
    ]}
    titleHtml="THEME &amp;<br />CONCEPT"
    description="A curated world built around your occasion — menu, presentation, and service all woven into a single cohesive experience."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={themeCatering}
    quote="A theme is not decoration — it's the flavour of the entire evening."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Discuss Your Concept</Button>
      <Button href="/services" variant="outlineCream">All Services</Button>
    </div>
  </PageHero>

  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Concept · Immersive · Singular
      </div>
    </div>
    <div>
      <SectionEyebrow class="mb-4">Concept Catering</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Food as the <em class="italic text-dark-red">centrepiece of your world</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Themed and concept events ask more of catering than any other format. The food must live inside the world being created — not just exist alongside it. We work from the concept brief outward, designing menus, service formats, station aesthetics, and presentation that all feel native to the theme.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The best themed event is one where guests forget they're at a catered event — they're inside an experience."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        From rustic Indian haveli evenings to elegant European garden parties — we've built immersive food experiences for corporate launches, weddings, and private events.
      </p>
      <Button href="/contact/get-a-quote" variant="storyLink">Discuss Your Concept</Button>
    </div>
  </section>

  <section class="grid grid-cols-1 items-center gap-10 bg-dark-red px-5 py-20 md:gap-20 md:px-10 lg:grid-cols-2 lg:px-20 lg:py-20">
    <div>
      <span class="mb-4 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">Popular Themes</span>
      <h2 class="font-serif text-[clamp(30px,3.5vw,48px)] font-light leading-tight text-cream">
        Worlds we've <em class="italic">built before</em>
      </h2>
      <p class="mt-6 max-w-[440px] font-body text-xl leading-[1.85] text-cream/70">
        These are starting points — every concept is refined to reflect your occasion, venue, and vision.
      </p>
      <div class="mt-11 flex flex-wrap items-center gap-5">
        <Button href="/contact/get-a-quote" variant="cream">Discuss Your Concept</Button>
      </div>
    </div>
    <div class="grid grid-cols-1 gap-0.5 sm:grid-cols-2">
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">Indian Heritage</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Rajasthani haveli evenings, Mughal courts, coastal feasts</span>
      </Card>
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">International</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Mediterranean gardens, Italian suppers, Asian night markets</span>
      </Card>
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">Contemporary</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Garden cocktails, rooftop sundowners, industrial loft dinners</span>
      </Card>
      <Card variant="experienceTile">
        <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-blush uppercase">Bespoke</span>
        <span class="font-serif text-xl italic leading-snug text-cream">Your concept, built from scratch with our culinary team</span>
      </Card>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
