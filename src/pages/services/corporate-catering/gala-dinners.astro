---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import ChildServiceHero from '@/components/services/ChildServiceHero.astro';
import ServiceStatsStrip from '@/components/services/ServiceStatsStrip.astro';
import ServiceWhatYouGet from '@/components/services/ServiceWhatYouGet.astro';
import Testimonials from '@/components/home/showcase/Testimonials.astro';
import { corporateGala } from '@/lib/hero-images';
---

<BaseLayout
  title="Gala Dinner Catering — Elamrit Luxe Feast"
  description="Corporate gala dinner catering — award evenings, annual celebrations, and charity nights delivered as a full sensory experience by Elamrit Luxe Feast."
  bottomCta="home"
>
  <Nav variant="solid" />

  <ChildServiceHero
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Corporate Catering', href: '/services/corporate-catering' },
      { label: 'Gala Dinners' },
    ]}
    titleHtml="GALA<br />DINNERS"
    heroImageSrc={corporateGala}
    description="Annual celebrations, award evenings, charity galas — a full sensory experience from arrival drinks to the final dessert."
    primaryCtaHref="/contact/get-a-quote"
    primaryCtaLabel="Get a Quote"
    secondaryCtaHref="/services/corporate-catering"
    secondaryCtaLabel="All Corporate Services"
  />

  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Gala · Awards · Annual
      </div>
    </div>
    <div>
      <SectionEyebrow class="mb-4">Gala Catering</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        A night that earns <em class="italic text-dark-red">its standing ovation</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Gala dinners are the most visible corporate events of the year — guests remember what they ate, how it was served, and how the evening felt. We choreograph the entire food experience to match the scale and prestige of the occasion.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "A gala dinner is a company's handshake to everyone in the room. Make it memorable."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Arrival cocktails, a curated multi-course dinner, and a theatrical dessert reveal — we design the arc from welcome to farewell.
      </p>
    </div>
  </section>

  <section class="px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]" style="background: var(--bg-philosophy)">
    <div class="mb-16 grid grid-cols-1 items-end gap-6 md:mb-20 lg:grid-cols-[1fr_2fr] lg:gap-[60px]">
      <h2 class="font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        The Full <em class="italic text-dark-red">Arc</em>
      </h2>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        From arrival to the final toast, every moment of your gala dinner is planned, paced, and executed with ceremony.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-0.5 lg:grid-cols-3">
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">01</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M22 6C22 6 8 14 8 26C8 33.7 14.3 40 22 40C29.7 40 36 33.7 36 26C36 14 22 6 22 6Z" />
          <path d="M22 16V32M16 24L22 16L28 24" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Arrival &amp; Cocktail Hour</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Curated arrival drinks, elegant canapé service, and roaming starters that set the tone before dinner even begins.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">02</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="22" cy="22" r="16" />
          <path d="M22 8v8M22 28v8M8 22h8M28 22h8" />
          <circle cx="22" cy="22" r="4" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Plated Multi-course Dinner</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          A composed dinner with pacing aligned to your awards programme — courses timed around speeches, presentations, and entertainment.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">03</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M10 34C10 34 12 20 22 14C32 20 34 34 34 34" />
          <path d="M16 28C16 28 18 22 22 20C26 22 28 28 28 28" />
          <line x1="10" y1="34" x2="34" y2="34" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Dessert Theatre</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          A dramatic dessert finale — plated or live stations — that gives guests a final memorable moment before the evening closes.
        </p>
      </Card>
    </div>
  </section>

  <ServiceStatsStrip
    items={[
      { label: 'Format', value: 'Plated & Buffet' },
      { label: 'Scale', value: '100 – 1,500' },
      { label: 'Add-on', value: 'Live Dessert Station' },
      { label: 'Timing', value: 'Programme-synced' },
    ]}
  />

  <ServiceWhatYouGet
    titleHtml="What makes gala nights feel <em>grand</em>"
    description="Gala dinners are visible, ceremonial, and time-sensitive. We choreograph arrival canapés, plated courses, and dessert theatre around your programme so every moment lands."
    bullets={[
      'Arrival cocktails + canapé service design',
      'Programme-synced multi-course dinner pacing',
      'Backstage coordination with AV/awards schedule',
      'Dessert theatre and finale planning',
      'VIP dietary handling with discreet service',
    ]}
    ctaHref="/contact/get-a-quote"
    ctaLabel="Request a Quote"
  />

  <Testimonials />

  <SiteFooter slot="footer" />
</BaseLayout>
