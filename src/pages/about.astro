---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/shared/Nav.astro';
import AboutPageHero from '../components/about/intro/AboutPageHero.astro';
import AboutStory from '../components/about/story/AboutStory.astro';
import AboutPhilosophy from '../components/about/story/AboutPhilosophy.astro';
import AboutValuesStrip from '../components/about/story/AboutValuesStrip.astro';
import AboutStats from '../components/about/story/AboutStats.astro';
import AboutTeam from '../components/about/company/AboutTeam.astro';
import AboutLocations from '../components/about/company/AboutLocations.astro';
import SiteFooter from '../components/shared/SiteFooter.astro';
---

<BaseLayout
  title="About Elamrit — Our Story, Philosophy & Team"
  description="Learn the story behind Elamrit Luxe Feast — the philosophy, the people, and the passion that drives premium catering across Pune and Pan India."
  bottomCta="about"
>
  <Nav variant="solid" />
  <AboutPageHero />
  <AboutStory />
  <AboutPhilosophy />
  <AboutValuesStrip />
  <AboutStats />
  <AboutTeam />
  <AboutLocations />
  <SiteFooter slot="footer" />
</BaseLayout>
