---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import MenuGallery from '@/components/menus/MenuGallery.astro';
---

<BaseLayout
  title="Custom Menu Builder — Elamrit Luxe Feast"
  description="Design a bespoke catering menu with Elamrit. Share your occasion, cuisine preferences, dietary requirements, and service style — we'll compose a menu built entirely around you."
>
  <Nav variant="solid" />

  <PageHero
    variant="center"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Menus', href: '/menus' },
      { label: 'Custom Menu' },
    ]}
    titleHtml="BUILD YOUR<br />MENU"
    description="No fixed menus, no generic packages. Tell us your vision — we'll compose something that feels exactly right for your occasion."
    descriptionClass="mx-auto max-w-[720px]"
  >
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href="/menus" variant="outlineCream">Browse Menu Categories</Button>
      <Button href="/contact/get-a-quote" variant="outlineCream">Get a Full Quote</Button>
    </div>
  </PageHero>

  <!-- How it works -->
  <section class="px-5 py-16 md:px-10 lg:px-20 lg:py-20 bg-cream">
    <div class="mx-auto w-full max-w-[1100px]">
      <SectionHeader class="mb-12" label="The Process" align="center" showDivider={true}>
        How a custom menu <em>comes together</em>
      </SectionHeader>
      <div class="grid grid-cols-1 gap-0.5 md:grid-cols-3">
        <Card variant="pillar">
          <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">01</div>
          <h3 class="pillar-title mb-3 font-serif text-xl font-normal text-dark-brown">Share your brief</h3>
          <div class="mb-5 h-0.5 w-8 bg-dark-red"></div>
          <p class="font-body text-[16px] leading-[1.75] text-[var(--text-muted-on-cream)]">
            Fill out the form below — occasion, guest count, cuisine direction, dietary needs, and service style. The more detail you share, the better we can respond.
          </p>
        </Card>
        <Card variant="pillar">
          <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">02</div>
          <h3 class="pillar-title mb-3 font-serif text-xl font-normal text-dark-brown">We compose a direction</h3>
          <div class="mb-5 h-0.5 w-8 bg-dark-red"></div>
          <p class="font-body text-[16px] leading-[1.75] text-[var(--text-muted-on-cream)]">
            Our team reviews your brief and responds with a considered menu direction — not a generic list, but a curated proposal matched to your occasion and palate.
          </p>
        </Card>
        <Card variant="pillar">
          <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">03</div>
          <h3 class="pillar-title mb-3 font-serif text-xl font-normal text-dark-brown">Refine together</h3>
          <div class="mb-5 h-0.5 w-8 bg-dark-red"></div>
          <p class="font-body text-[16px] leading-[1.75] text-[var(--text-muted-on-cream)]">
            We iterate on the menu through conversation — adjusting courses, swapping dishes, and finalising every detail until it feels completely right.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <MenuGallery
    label="Bespoke menus"
    tile1={{
      imageSrc: '/images/menus/gallery-custom-1.png',
      imageAlt: 'Menu planning still life with spices, cream paper, and burgundy accents — bespoke Elamrit brief.',
      caption: 'Your brief',
    }}
    tile2={{
      imageSrc: '/images/menus/gallery-custom-2.png',
      imageAlt: 'Row of refined tasting plates for a private menu preview.',
      caption: 'Tasting & direction',
    }}
    tile3={{
      imageSrc: '/images/menus/gallery-custom-3.png',
      imageAlt: 'Styled place setting with cream charger and burgundy napkin — bespoke event table.',
      caption: 'The table',
    }}
  />

  <!-- Custom menu form -->
  <section class="px-5 py-16 md:px-10 lg:px-20 lg:py-24" style="background: var(--bg-services-home)">
    <div class="mx-auto w-full max-w-[980px]">
      <SectionHeader class="mb-10" label="Menu Brief" align="center" showDivider={true}>
        Tell us about your <em>event</em>
      </SectionHeader>

      <Card class="p-7 md:p-10">
        <form class="grid grid-cols-1 gap-5 md:grid-cols-2" method="post" action="#">

          <!-- Occasion -->
          <div class="md:col-span-2">
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Occasion</div>
            <select
              name="occasion"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              required
            >
              <option value="" selected disabled>Select one</option>
              <option>Wedding reception</option>
              <option>Pre-wedding (haldi, mehendi, sangeet)</option>
              <option>Corporate event or conference</option>
              <option>Gala dinner</option>
              <option>Birthday or anniversary celebration</option>
              <option>Cocktail party or social gathering</option>
              <option>Private dining</option>
              <option>Other</option>
            </select>
          </div>

          <!-- Cuisine direction (multi-select via checkboxes) -->
          <div class="md:col-span-2">
            <div class="mb-3 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Cuisine direction <span class="normal-case tracking-normal text-[var(--text-muted-on-cream-soft)]">(select all that apply)</span></div>
            <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
              {[
                'Indian — North',
                'Indian — South',
                'Indian — Regional',
                'International / Continental',
                'Mediterranean',
                'Pan-Asian',
                'Fusion',
                'Not sure — open to suggestions',
              ].map((option) => (
                <label class="flex cursor-pointer items-center gap-3 rounded-sm border border-[rgba(189,148,118,0.25)] bg-cream px-4 py-3 font-body text-[15px] leading-[1.5] text-dark-brown transition-colors hover:border-dark-red/30 has-[:checked]:border-dark-red/50 has-[:checked]:bg-light-blush">
                  <input
                    type="checkbox"
                    name="cuisine"
                    value={option}
                    class="h-4 w-4 flex-shrink-0 accent-[var(--dark-red)]"
                  />
                  {option}
                </label>
              ))}
            </div>
          </div>

          <!-- Dietary requirements -->
          <div class="md:col-span-2">
            <div class="mb-3 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Dietary requirements <span class="normal-case tracking-normal text-[var(--text-muted-on-cream-soft)]">(select all that apply)</span></div>
            <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
              {[
                'Pure vegetarian',
                'Jain',
                'Non-vegetarian',
                'Vegan',
                'Gluten-free',
                'Nut-free',
                'Halal',
                'Mixed (all of the above)',
              ].map((option) => (
                <label class="flex cursor-pointer items-center gap-3 rounded-sm border border-[rgba(189,148,118,0.25)] bg-cream px-4 py-3 font-body text-[15px] leading-[1.5] text-dark-brown transition-colors hover:border-dark-red/30 has-[:checked]:border-dark-red/50 has-[:checked]:bg-light-blush">
                  <input
                    type="checkbox"
                    name="dietary"
                    value={option}
                    class="h-4 w-4 flex-shrink-0 accent-[var(--dark-red)]"
                  />
                  {option}
                </label>
              ))}
            </div>
          </div>

          <!-- Service style -->
          <div class="md:col-span-2">
            <div class="mb-3 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Preferred service style</div>
            <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
              {[
                'Buffet',
                'Plated / Seated',
                'Live stations',
                'Not sure',
              ].map((option) => (
                <label class="flex cursor-pointer items-center gap-3 rounded-sm border border-[rgba(189,148,118,0.25)] bg-cream px-4 py-3 font-body text-[15px] leading-[1.5] text-dark-brown transition-colors hover:border-dark-red/30 has-[:checked]:border-dark-red/50 has-[:checked]:bg-light-blush">
                  <input
                    type="radio"
                    name="service_style"
                    value={option}
                    class="h-4 w-4 flex-shrink-0 accent-[var(--dark-red)]"
                  />
                  {option}
                </label>
              ))}
            </div>
          </div>

          <!-- Guest count -->
          <div>
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Approximate guest count</div>
            <input
              name="guests"
              type="number"
              min="1"
              inputmode="numeric"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              placeholder="e.g. 200"
              required
            />
          </div>

          <!-- Event date -->
          <div>
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Event date</div>
            <input
              name="date"
              type="date"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              required
            />
          </div>

          <!-- City -->
          <div>
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">City / Venue</div>
            <input
              name="city"
              autocomplete="address-level2"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              placeholder="Pune, Mumbai, Pan India…"
              required
            />
          </div>

          <!-- Budget range -->
          <div>
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Budget range <span class="normal-case tracking-normal text-[var(--text-muted-on-cream-soft)]">(per person, optional)</span></div>
            <select
              name="budget"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
            >
              <option value="" selected disabled>Prefer not to say</option>
              <option>Under ₹800 per person</option>
              <option>₹800 – ₹1,500 per person</option>
              <option>₹1,500 – ₹2,500 per person</option>
              <option>₹2,500 – ₹4,000 per person</option>
              <option>Above ₹4,000 per person</option>
            </select>
          </div>

          <!-- Contact details -->
          <div>
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Full name</div>
            <input
              name="name"
              autocomplete="name"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              placeholder="Your name"
              required
            />
          </div>

          <div>
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Phone / WhatsApp</div>
            <input
              name="phone"
              inputmode="tel"
              autocomplete="tel"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              placeholder="+91 …"
              required
            />
          </div>

          <div class="md:col-span-2">
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Email</div>
            <input
              name="email"
              type="email"
              autocomplete="email"
              class="w-full rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.6] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              placeholder="you@example.com"
              required
            />
          </div>

          <!-- Additional notes -->
          <div class="md:col-span-2">
            <div class="mb-2 font-body text-[11px] tracking-[0.26em] text-gray-orange uppercase">Anything else we should know</div>
            <textarea
              name="notes"
              rows={4}
              class="w-full resize-y rounded-sm border border-[rgba(189,148,118,0.35)] bg-cream px-4 py-3 font-body text-[16px] leading-[1.7] text-dark-brown outline-none transition-[border-color,box-shadow] duration-200 focus:border-dark-red/40 focus:shadow-[0_0_0_3px_rgba(81,3,12,0.08)]"
              placeholder="Specific dishes you love, cuisines to avoid, cultural context, venue constraints, live station ideas…"
            />
            <p class="mt-3 font-body text-[14px] leading-[1.7] text-[var(--text-muted-on-cream-soft)]">
              This form is currently a design placeholder (static site). For now, please email
              <a class="text-dark-red underline decoration-[rgba(81,3,12,0.35)] underline-offset-4" href="mailto:hello@elamrit.example"
                >hello@elamrit.example</a
              >
              with these details.
            </p>
          </div>

          <div class="md:col-span-2 mt-2 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <Button type="submit" variant="navCta">Submit Menu Brief</Button>
            <a class="btn-ghost text-dark-red" href="/contact/get-a-quote">Want a full quote instead?</a>
          </div>

        </form>
      </Card>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
