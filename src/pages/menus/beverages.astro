---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import Card from '@/components/ui/Card.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import ChildServiceHero from '@/components/services/ChildServiceHero.astro';
import ServiceStatsStrip from '@/components/services/ServiceStatsStrip.astro';
import ServiceWhatYouGet from '@/components/services/ServiceWhatYouGet.astro';
import Testimonials from '@/components/home/showcase/Testimonials.astro';
import MenuGallery from '@/components/menus/MenuGallery.astro';
import { menuBeverages } from '@/lib/hero-images';
---

<BaseLayout
  title="Beverages — Elamrit Luxe Feast"
  description="Beverage catering by Elamrit — welcome drinks, signature sherbets, mocktails, and non-alcoholic pairings curated to complement your menu from arrival to last toast."
  bottomCta="about"
>
  <Nav variant="solid" />

  <ChildServiceHero
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Menus', href: '/menus' },
      { label: 'Beverages' },
    ]}
    titleHtml="BEVERAGES"
    heroImageSrc={menuBeverages}
    description="From the first welcome drink to the final toast — curated non-alcoholic beverages that set the tone, complement the food, and keep your guests refreshed throughout."
    primaryCtaHref="/menus/custom-menu"
    primaryCtaLabel="Build a Custom Menu"
    secondaryCtaHref="/menus"
    secondaryCtaLabel="All Menu Categories"
  />

  <!-- Feature section -->
  <section
    id="beverages-story"
    class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]"
  >
    <div>
      <SectionEyebrow class="mb-4">The First Impression</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        The drink they remember <em class="italic text-dark-red">arriving</em> to
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        A beverage programme is often the first sensory experience a guest has at your event. A chilled sherbet on arrival, a signature mocktail on trays at the door — these small moments signal care and set the register for everything that follows.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "What you hand a guest the moment they arrive tells them everything about the evening ahead."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We design beverage programmes that are fully non-alcoholic — because our events are family-inclusive by nature — and composing them with the same rigour we bring to food. Seasonal ingredients, house syrups, thoughtful garnishes.
      </p>
    </div>
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
    </div>
  </section>

  <!-- Pillars -->
  <section id="beverages-pillars" class="px-5 py-20 md:px-10 lg:px-20 lg:py-[110px]" style="background: var(--bg-philosophy)">
    <div class="mb-16 grid grid-cols-1 items-end gap-6 md:mb-20 lg:grid-cols-[1fr_2fr] lg:gap-[60px]">
      <h2 class="font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        What We <em class="italic text-dark-red">Offer</em>
      </h2>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        A complete non-alcoholic beverage programme covering every moment of your event — arrival, dining, and the sweet finish.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-0.5 lg:grid-cols-3">
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">01</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="22" cy="22" r="16" />
          <path d="M22 8v8M22 28v8M8 22h8M28 22h8" />
          <circle cx="22" cy="22" r="4" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Welcome Drinks</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Signature sherbets, nimbu pani, aam panna, spiced coolers — a curated welcome that refreshes on arrival and reflects the season and the occasion.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">02</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M22 6C22 6 8 14 8 26C8 33.7 14.3 40 22 40C29.7 40 36 33.7 36 26C36 14 22 6 22 6Z" />
          <path d="M22 16V32M16 24L22 16L28 24" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Mocktails &amp; Signature Blends</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Elegant non-alcoholic cocktails — virgin mojitos, rose lychee sparklers, tamarind coolers — with house-made syrups and garnishes.
        </p>
      </Card>
      <Card variant="pillar">
        <div class="pointer-events-none absolute top-8 right-8 font-display text-[52px] leading-none tracking-wide text-dark-red/25">03</div>
        <svg class="mb-7 h-11 w-11 text-gray-orange" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M10 34C10 34 12 20 22 14C32 20 34 34 34 34" />
          <path d="M16 28C16 28 18 22 22 20C26 22 28 28 28 28" />
          <line x1="10" y1="34" x2="34" y2="34" />
        </svg>
        <h3 class="pillar-title mb-4 font-serif text-2xl font-normal text-dark-brown">Dining Pairings</h3>
        <div class="mb-6 h-0.5 w-8 bg-dark-red"></div>
        <p class="font-body text-[17px] leading-[1.75] text-[var(--text-muted-on-cream)]">
          Curated non-alcoholic pairings served alongside plated courses — complementing flavour profiles without overwhelming the food, especially for formal dinners.
        </p>
      </Card>
    </div>
  </section>

  <MenuGallery
    label="Beverages"
    tile1={{
      imageSrc: '/images/menus/gallery-beverages-1.png',
      imageAlt: 'Sparkling welcome mocktail in a crystal flute with petals — non-alcoholic Elamrit beverage.',
      caption: 'Welcome drinks',
    }}
    tile2={{
      imageSrc: '/images/menus/gallery-beverages-2.png',
      imageAlt: 'Two artisan mocktails with citrus, mint, and ice on a copper tray.',
      caption: 'Signature mocktails',
    }}
    tile3={{
      imageSrc: '/images/menus/gallery-beverages-3.png',
      imageAlt: 'Elegant beverage dispensers with fruit and herb garnishes on a styled counter.',
      caption: 'Beverage counter',
    }}
  />

  <ServiceStatsStrip
    items={[
      { label: 'Style', value: 'Non-Alcoholic' },
      { label: 'Options', value: 'Indian · Global' },
      { label: 'Service', value: 'Tray · Counter · Table' },
      { label: 'Best For', value: 'All Events' },
    ]}
  />

  <ServiceWhatYouGet
    label="What's included"
    titleHtml="Beverages that <em>elevate</em> the experience"
    description="Every beverage at an Elamrit event is freshly prepared, seasonally influenced, and matched to the occasion. We design the full programme from arrival to closing."
    bullets={[
      'Welcome drink — curated for season and occasion',
      'Signature mocktails and house-blend sherbets',
      'Non-alcoholic dining pairings for formal menus',
      'Beverage counters and tray service available',
      'Hot beverages — chai, filter coffee, herbal infusions',
      'Hydration stations for outdoor and day-long events',
    ]}
    ctaHref="/menus/custom-menu"
    ctaLabel="Plan a Beverage Programme"
  />

  <Testimonials />

  <SiteFooter slot="footer" />
</BaseLayout>
