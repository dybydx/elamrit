---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import { cateringPune } from '@/lib/hero-images';
---

<BaseLayout
  title="Catering in Pune — Elamrit Luxe Feast"
  description="Luxury catering in Pune for weddings, corporate events, and social celebrations. Elamrit Luxe Feast is Pune's premium caterer — based here, perfected here."
  bottomCta="about"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Catering in Pune' },
    ]}
    titleHtml="CATERING<br />IN PUNE"
    description="Our home. Every standard we hold across India was born right here — in Pune's kitchens, at Pune's finest venues, for Pune's most discerning hosts."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={cateringPune}
    quote="Pune is where Elamrit was forged. Every deployment we make, anywhere in India, carries this city's obsessive preparation."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Plan Your Event</Button>
      <Button href="/catering-in/pune/wedding-catering" variant="outlineCream">Wedding Catering Pune</Button>
    </div>
  </PageHero>

  <!-- Story section -->
  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Pune HQ · Home Base
      </div>
    </div>
    <div>
      <SectionEyebrow class="mb-4">Pune — Our City</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Born in Pune, <em class="italic text-dark-red">trusted across India</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Elamrit was founded in Pune and this city remains our operational heart. Our central kitchen, core culinary team, and creative leadership are all rooted here — which means Pune clients receive not just our full service but our home-ground advantage. We know the city's venues intimately: their loading docks, kitchen configurations, seasonal logistics, and the expectations of Pune's most sophisticated hosts.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "Pune hosts expect perfection without pretence — refined, personal, and executed with genuine care."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        From intimate private dinners in Koregaon Park to grand wedding receptions at five-star properties and high-stakes corporate galas in Baner and Hinjewadi, we bring the same standards to every table.
      </p>
      <Button href="/contact/get-a-quote" variant="storyLink">Enquire for Pune</Button>
    </div>
  </section>

  <!-- Services in Pune -->
  <section class="bg-dark-red px-5 py-20 md:px-10 lg:px-20 lg:py-24">
    <div class="mb-14 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="mb-3 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">What We Offer in Pune</span>
        <h2 class="font-serif text-[clamp(28px,3.2vw,46px)] font-light leading-tight text-cream">
          Every occasion, <em class="italic">one team</em>
        </h2>
      </div>
      <p class="max-w-[420px] font-body text-[17px] leading-[1.8] text-cream/65 lg:text-right">
        Our full portfolio of services is available in Pune — from intimate gatherings to grand events for 1,000+ guests.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/services/wedding-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Weddings</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Wedding Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Hindu, multicultural, destination, and pre-wedding events — curated end to end.</p>
        </Card>
      </a>
      <a href="/services/corporate-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Corporate</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Corporate Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Conferences, product launches, business dining, and gala dinners in Pune's corporate belt.</p>
        </Card>
      </a>
      <a href="/services/social-celebrations" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Social</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Social Celebrations</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Birthdays, anniversaries, cocktail parties, and housewarming pujas.</p>
        </Card>
      </a>
      <a href="/services/private-dining" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Intimate</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Private Dining</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Chef-curated private experiences for 8–40 guests in residences or boutique venues.</p>
        </Card>
      </a>
      <a href="/services/live-stations" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Experiential</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Live Stations</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Theatrical food stations that become a centrepiece of the guest experience.</p>
        </Card>
      </a>
      <a href="/services/theme-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Themed</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Theme Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Immersive concept dining — from heritage Marathi spreads to global fusion themes.</p>
        </Card>
      </a>
    </div>
  </section>

  <!-- Venues section -->
  <section class="bg-light-blush px-5 py-20 md:px-10 lg:px-20 lg:py-[90px]">
    <div class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
      <div>
        <SectionEyebrow class="mb-4">Pune's Finest Addresses</SectionEyebrow>
        <h2 class="font-serif text-[clamp(28px,3vw,44px)] font-light leading-tight text-dark-brown">
          Venues we know <em class="italic text-dark-red">from the inside</em>
        </h2>
      </div>
      <div class="flex items-end">
        <Button href="/contact/get-a-quote" variant="outlineCta">Book Your Venue</Button>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-px bg-[rgba(189,148,118,0.2)] sm:grid-cols-3 lg:grid-cols-6">
      {[
        'JW Marriott',
        'Conrad Pune',
        'The Westin',
        'Hyatt Regency',
        'Taj Blue Diamond',
        'Sheraton Grand',
      ].map((venue) => (
        <div class="bg-cream px-5 py-6 text-center">
          <span class="font-body text-[13px] leading-[1.6] tracking-[0.06em] text-[var(--text-muted-on-cream)]">{venue}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 font-body text-[14px] text-[var(--text-muted-on-cream-soft)]">
      We work at any venue in Pune — the above are among our frequently served properties. Don't see your venue? We'll adapt to it.
    </p>
  </section>

  <!-- Pune Wedding Catering sub-link -->
  <section class="grid grid-cols-1 items-center gap-10 bg-dark-brown px-5 py-16 md:px-10 lg:grid-cols-[2fr_1fr] lg:gap-16 lg:px-20">
    <div>
      <span class="mb-3 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">Explore</span>
      <h2 class="font-serif text-[clamp(26px,3vw,42px)] font-light leading-tight text-cream">
        Pune Wedding Catering — <em class="italic">a dedicated guide</em>
      </h2>
      <p class="mt-4 max-w-[520px] font-body text-[17px] leading-[1.8] text-cream/65">
        Planning a wedding in Pune? We've put together a dedicated page with everything you need to know — venues, cuisines, guest pacing, and how we make your wedding extraordinary.
      </p>
    </div>
    <div class="flex lg:justify-end">
      <Button href="/catering-in/pune/wedding-catering" variant="creamOnDark">Wedding Catering in Pune</Button>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
