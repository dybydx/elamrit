---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import { cateringPuneWedding } from '@/lib/hero-images';
---

<BaseLayout
  title="Wedding Catering in Pune — Elamrit Luxe Feast"
  description="Premium wedding catering in Pune — from intimate ceremonies to grand receptions. Elamrit Luxe Feast crafts bespoke culinary experiences at Pune's finest venues."
  bottomCta="about"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Catering in Pune', href: '/catering-in/pune' },
      { label: 'Wedding Catering' },
    ]}
    titleHtml="WEDDING<br />CATERING<br />IN PUNE"
    description="Pune is one of India's most celebrated wedding cities — and we've been at the centre of its most remarkable celebrations."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={cateringPuneWedding}
    quote="A Pune wedding deserves a culinary experience that honours its grandeur and reflects its warmth."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Plan Your Wedding</Button>
      <Button href="/services/wedding-catering" variant="outlineCream">All Wedding Services</Button>
    </div>
  </PageHero>

  <!-- Story -->
  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Pune Weddings · Our Speciality
      </div>
    </div>
    <div>
      <SectionEyebrow class="mb-4">Pune's Wedding Caterer</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Every ceremony, <em class="italic text-dark-red">every tradition</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Pune's wedding scene is as diverse as the city itself — Maharashtrian traditions with their rich ritual and flavour, North Indian grandeur, fusion celebrations spanning multiple cultures, and destination events hosted at the city's landmark five-star properties. We've catered them all, and we design every menu and service flow to honour the specific occasion.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "Each family has its own idea of a perfect wedding feast. Our work is to understand that vision before we design a single course."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        From mehendi and sangeet to the main reception and next-day brunch, we handle every food touchpoint of the wedding with the same precision — so the family never worries about a single plate.
      </p>
      <Button href="/contact/get-a-quote" variant="storyLink">Begin Your Wedding Plan</Button>
    </div>
  </section>

  <!-- Wedding types -->
  <section class="bg-dark-red px-5 py-20 md:px-10 lg:px-20 lg:py-24">
    <div class="mb-14">
      <span class="mb-3 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">Wedding Catering Specialisations</span>
      <h2 class="font-serif text-[clamp(28px,3.2vw,46px)] font-light leading-tight text-cream">
        The full wedding <em class="italic">experience</em>
      </h2>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <a href="/services/wedding-catering/hindu-weddings" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Traditional</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Hindu Weddings</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Authentic regional cuisines, ritual-sensitive menus, and seamless multi-event pacing.</p>
        </Card>
      </a>
      <a href="/services/wedding-catering/pre-wedding-events" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Pre-Wedding</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Pre-Wedding Events</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Mehendi, sangeet, and cocktail evenings — each with its own distinct culinary character.</p>
        </Card>
      </a>
      <a href="/services/wedding-catering/destination-weddings" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Destination</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Destination Weddings</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Pune-based planning with seamless deployment to Goa, Rajasthan, or any dream location.</p>
        </Card>
      </a>
      <a href="/services/wedding-catering/multicultural-weddings" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Multicultural</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Multicultural Weddings</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Harmonising cuisines and traditions across families from different backgrounds.</p>
        </Card>
      </a>
    </div>
  </section>

  <!-- Venues -->
  <section class="bg-light-blush px-5 py-20 md:px-10 lg:px-20 lg:py-[90px]">
    <div class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
      <div>
        <SectionEyebrow class="mb-4">Pune Wedding Venues</SectionEyebrow>
        <h2 class="font-serif text-[clamp(28px,3vw,44px)] font-light leading-tight text-dark-brown">
          Venues we've <em class="italic text-dark-red">celebrated at</em>
        </h2>
      </div>
      <div class="flex items-end">
        <Button href="/contact/get-a-quote" variant="outlineCta">Get a Quote</Button>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-px bg-[rgba(189,148,118,0.2)] sm:grid-cols-3 lg:grid-cols-6">
      {[
        'JW Marriott',
        'Conrad Pune',
        'Taj Blue Diamond',
        'The Westin',
        'Hyatt Regency',
        'Sheraton Grand',
      ].map((venue) => (
        <div class="bg-cream px-5 py-6 text-center">
          <span class="font-body text-[13px] leading-[1.6] tracking-[0.06em] text-[var(--text-muted-on-cream)]">{venue}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 font-body text-[14px] text-[var(--text-muted-on-cream-soft)]">
      We cater at any venue in Pune — hotels, farmhouses, heritage properties, and private residences. Tell us your venue and we'll take it from there.
    </p>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
