---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import { cateringDelhiNcr } from '@/lib/hero-images';
---

<BaseLayout
  title="Catering in Delhi & NCR — Elamrit Luxe Feast"
  description="Luxury catering in Delhi NCR for grand weddings, conferences, and high-profile events. Elamrit Luxe Feast delivers Pune's meticulous standards to the capital."
  bottomCta="about"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Locations', href: '/catering-in' },
      { label: 'Delhi' },
    ]}
    titleHtml="CATERING<br />IN DELHI<br />NCR"
    description="India's capital hosts its grandest celebrations — from diplomatic gatherings to landmark weddings. We bring Elamrit's standard of excellence to every one."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={cateringDelhiNcr}
    quote="Delhi demands scale without compromise. We've learned to deliver both."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Plan Your Event</Button>
      <Button href="/services/pan-india-catering" variant="outlineCream">Our Pan India Operations</Button>
    </div>
  </PageHero>

  <!-- Story section -->
  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Delhi NCR · Weddings & Events
      </div>
    </div>
    <div>
      <SectionEyebrow class="mb-4">Operating in Delhi NCR</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        The capital's scale, <em class="italic text-dark-red">our craft</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Delhi NCR is India's stage for its most opulent weddings and its most consequential corporate events. The expectations are high, the guest lists are distinguished, and the logistical complexity is real. We've deployed to Delhi for weddings in Lutyens' Delhi, conferences in Gurugram's business district, and social galas in Noida — each requiring a different operational approach but the same uncompromising quality.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The best Delhi hosts notice everything. That's why we prepare for everything."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        We begin every Delhi deployment with an advance team visit, comprehensive venue assessment, and tasting sessions for key decision-makers — ensuring the event day is purely about celebration.
      </p>
      <Button href="/contact/get-a-quote" variant="storyLink">Enquire for Delhi NCR</Button>
    </div>
  </section>

  <!-- Services in Delhi NCR -->
  <section class="bg-dark-red px-5 py-20 md:px-10 lg:px-20 lg:py-24">
    <div class="mb-14 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="mb-3 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">What We Offer in Delhi NCR</span>
        <h2 class="font-serif text-[clamp(28px,3.2vw,46px)] font-light leading-tight text-cream">
          Grand occasions, <em class="italic">exacting standards</em>
        </h2>
      </div>
      <p class="max-w-[420px] font-body text-[17px] leading-[1.8] text-cream/65 lg:text-right">
        Weddings, conferences, and high-profile events — we deliver our full portfolio across Delhi, Gurugram, and Noida.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/services/wedding-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Weddings</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Wedding Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Grand wedding catering for Delhi's most prestigious properties and banquet halls.</p>
        </Card>
      </a>
      <a href="/services/destination-weddings" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Destination</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Destination Weddings</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Delhi-coordinated destination weddings — Rajasthan, Himachal, and beyond.</p>
        </Card>
      </a>
      <a href="/services/corporate-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Corporate</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Corporate Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Conferences, summits, and corporate galas for Delhi's business and diplomatic community.</p>
        </Card>
      </a>
      <a href="/services/social-celebrations" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Social</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Social Celebrations</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Milestone celebrations and private gatherings curated with Delhi's refined sensibility.</p>
        </Card>
      </a>
      <a href="/services/theme-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Themed</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Theme Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Immersive concept dining — heritage Mughal spreads, global cuisines, and bespoke themes.</p>
        </Card>
      </a>
      <a href="/services/private-dining" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Intimate</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Private Dining</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Bespoke private dining experiences for distinguished hosts in the capital.</p>
        </Card>
      </a>
    </div>
  </section>

  <!-- Venues section -->
  <section class="bg-light-blush px-5 py-20 md:px-10 lg:px-20 lg:py-[90px]">
    <div class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
      <div>
        <SectionEyebrow class="mb-4">Delhi NCR's Finest Properties</SectionEyebrow>
        <h2 class="font-serif text-[clamp(28px,3vw,44px)] font-light leading-tight text-dark-brown">
          Venues we've <em class="italic text-dark-red">celebrated at</em>
        </h2>
      </div>
      <div class="flex items-end">
        <Button href="/contact/get-a-quote" variant="outlineCta">Book Your Event</Button>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-px bg-[rgba(189,148,118,0.2)] sm:grid-cols-3 lg:grid-cols-6">
      {[
        'The Imperial',
        'Taj Palace Delhi',
        'The Leela Palace',
        'ITC Maurya',
        'The Lodhi',
        'Oberoi New Delhi',
      ].map((venue) => (
        <div class="bg-cream px-5 py-6 text-center">
          <span class="font-body text-[13px] leading-[1.6] tracking-[0.06em] text-[var(--text-muted-on-cream)]">{venue}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 font-body text-[14px] text-[var(--text-muted-on-cream-soft)]">
      We cater across Delhi, Gurugram, Noida, and greater NCR. Share your venue and we'll plan accordingly.
    </p>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
