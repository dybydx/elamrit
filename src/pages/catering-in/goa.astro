---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/shared/Nav.astro';
import PageHero from '@/components/shared/PageHero.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import SectionEyebrow from '@/components/shared/SectionEyebrow.astro';
import SiteFooter from '@/components/shared/SiteFooter.astro';
import { cateringGoa } from '@/lib/hero-images';
---

<BaseLayout
  title="Catering in Goa — Elamrit Luxe Feast"
  description="Premium destination wedding and event catering in Goa — beach resorts, heritage villas, and luxury hotels. Elamrit Luxe Feast brings Pan India operations to India's favourite coast."
  bottomCta="about"
>
  <Nav variant="solid" />

  <PageHero
    variant="split"
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Locations', href: '/catering-in' },
      { label: 'Goa' },
    ]}
    titleHtml="CATERING<br />IN GOA"
    description="Goa is where celebrations open up — sea air, open lawns, and nights that run long. We bring the same backstage discipline, adapted for sand, salt, and starlight."
    descriptionClass="w-full max-w-none"
    imageClass="ph-image"
    heroImageSrc={cateringGoa}
    quote="A Goa event should feel free — never improvised. The rigour happens before anyone arrives."
    quoteAttribution="Elamrit"
  >
    <div class="mt-8 flex flex-wrap gap-4">
      <Button href="/contact/get-a-quote" variant="creamOnDark">Plan Your Event</Button>
      <Button href="/services/destination-weddings" variant="outlineCream">Destination Weddings</Button>
    </div>
  </PageHero>

  <section class="grid grid-cols-1 items-center gap-16 bg-cream px-5 py-20 md:gap-24 md:px-10 lg:grid-cols-2 lg:gap-[100px] lg:px-20 lg:py-[110px]">
    <div class="story-image relative">
      <div class="story-img-main relative aspect-[3/4] w-full overflow-hidden bg-[color-mix(in_srgb,var(--cream)_72%,var(--gray-orange)_28%)]"></div>
      <div class="story-img-float absolute -right-10 -bottom-10 hidden aspect-square w-[55%] overflow-hidden bg-dark-red md:block"></div>
      <div class="absolute -left-5 top-7 bg-dark-red px-5 py-3 font-display text-xs tracking-[0.26em] text-cream uppercase">
        Goa · Destination & Beach
      </div>
    </div>
    <div>
      <SectionEyebrow class="mb-4">Operating in Goa</SectionEyebrow>
      <h2 class="mb-8 font-serif text-[clamp(30px,3.5vw,46px)] font-light leading-tight text-dark-brown">
        Coast, climate, <em class="italic text-dark-red">and craft</em>
      </h2>
      <p class="mb-5 font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        Goa demands a caterer who understands outdoor logistics — power, refrigeration, coastal weather, and venue access across North and South Goa. We've catered at beachfront resorts, Portuguese-era villas, and private estates, coordinating with Pune-based planning and on-ground teams so the host never manages a single vendor handover alone.
      </p>
      <blockquote class="my-9 border-l-[3px] border-dark-red bg-light-blush py-4 pr-7 pl-7">
        <p class="m-0 font-serif text-[clamp(19px,2vw,22px)] italic leading-[1.65] text-dark-brown">
          "The best Goa weddings feel effortless. That feeling is the result of weeks of invisible preparation."
        </p>
      </blockquote>
      <p class="font-body text-[18px] leading-[1.85] text-[var(--text-muted-on-cream)]">
        From multi-day destination weddings to corporate offsites and intimate beachfront celebrations, we design menus and service flow around your venue — not the other way around.
      </p>
      <Button href="/contact/get-a-quote" variant="storyLink">Enquire for Goa</Button>
    </div>
  </section>

  <section class="bg-dark-red px-5 py-20 md:px-10 lg:px-20 lg:py-24">
    <div class="mb-14 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="mb-3 block font-body text-xs tracking-[0.28em] text-gray-orange uppercase">What We Offer in Goa</span>
        <h2 class="font-serif text-[clamp(28px,3.2vw,46px)] font-light leading-tight text-cream">
          Destination-first <em class="italic">catering</em>
        </h2>
      </div>
      <p class="max-w-[420px] font-body text-[17px] leading-[1.8] text-cream/65 lg:text-right">
        Our Goa deployments use the same Pan India playbook — with coastal logistics built in.
      </p>
    </div>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <a href="/services/wedding-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Weddings</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Wedding Catering</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Beach and resort weddings — multi-day celebrations with consistent quality across every function.</p>
        </Card>
      </a>
      <a href="/services/destination-weddings" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Destination</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Destination Weddings</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Full destination coordination — Goa as a primary choice for India's most memorable weddings.</p>
        </Card>
      </a>
      <a href="/services/corporate-catering" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Corporate</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Corporate & Offsites</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Leadership offsites, brand experiences, and gala evenings at Goa's premium resorts.</p>
        </Card>
      </a>
      <a href="/services/social-celebrations" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Social</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Social Celebrations</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Milestone birthdays, anniversaries, and sunset cocktail evenings with a coastal rhythm.</p>
        </Card>
      </a>
      <a href="/services/live-stations" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Experiential</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Live Stations</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Grills, seafood, and regional live counters suited to open-air venues.</p>
        </Card>
      </a>
      <a href="/services/private-dining" class="block">
        <Card variant="location" class="h-full">
          <span class="mb-2 block font-body text-[10px] tracking-[0.25em] text-gray-orange uppercase">Intimate</span>
          <h3 class="mb-3 font-serif text-xl font-light leading-snug text-dark-brown">Private Dining</h3>
          <p class="font-body text-[15px] leading-[1.7] text-[var(--text-muted-on-cream)]">Chef-led private dinners in villas and boutique properties across Goa.</p>
        </Card>
      </a>
    </div>
  </section>

  <section class="bg-light-blush px-5 py-20 md:px-10 lg:px-20 lg:py-[90px]">
    <div class="mb-12 grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
      <div>
        <SectionEyebrow class="mb-4">Goa's Premier Venues</SectionEyebrow>
        <h2 class="font-serif text-[clamp(28px,3vw,44px)] font-light leading-tight text-dark-brown">
          Resorts &amp; estates <em class="italic text-dark-red">we work with</em>
        </h2>
      </div>
      <div class="flex items-end">
        <Button href="/contact/get-a-quote" variant="outlineCta">Book Your Event</Button>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-px bg-[rgba(189,148,118,0.2)] sm:grid-cols-3 lg:grid-cols-6">
      {[
        'Taj Holiday Village',
        'The Leela Goa',
        'Grand Hyatt Goa',
        'W Goa',
        'Alila Diwa',
        'St. Regis Goa',
      ].map((venue) => (
        <div class="bg-cream px-5 py-6 text-center">
          <span class="font-body text-[13px] leading-[1.6] tracking-[0.06em] text-[var(--text-muted-on-cream)]">{venue}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 font-body text-[14px] text-[var(--text-muted-on-cream-soft)]">
      We cater across North and South Goa — beach resorts, heritage homes, and private estates. Tell us your venue and we'll plan the logistics.
    </p>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
